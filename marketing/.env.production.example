# Backend Worker URL (Cloudflare Worker deployed URL)
VITE_API_URL=https://ink-flow-backend.your-domain.workers.dev

# Optional: override default backend URL for sync
VITE_BACKEND_URL=https://ink-flow-backend.your-domain.workers.dev

# API Key Auth (REQUIRED in production)
REQUIRE_API_KEY=true
SERVER_API_KEY=change_me_to_a_random_secret
