---
interface Props {
  /** 页面最后更新日期，格式 YYYY-MM-DD */
  lastUpdated: string;
  /** 作者名，默认 InkFlow Team */
  author?: string;
  /** 审核者 */
  reviewedBy?: string;
  /** 是否显示在页面上（默认 true） */
  visible?: boolean;
}

const { lastUpdated, author = "InkFlow Team", reviewedBy, visible = true } = Astro.props;

// 格式化日期：YYYY-MM-DD → Month DD, YYYY
const formatDate = (d: string) => {
  const date = new Date(d + "T00:00:00Z");
  return date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric", timeZone: "UTC" });
};
---

{visible && (
  <div class="page-meta flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-gray-500 mt-8 mb-4">
    <span class="last-updated">
      <svg class="inline-block h-3.5 w-3.5 mr-1 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      Last updated: <time datetime={lastUpdated}>{formatDate(lastUpdated)}</time>
    </span>
    {author && (
      <span class="author">
        <svg class="inline-block h-3.5 w-3.5 mr-1 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
        Written by {author}
      </span>
    )}
    {reviewedBy && (
      <span class="reviewed-by">
        <svg class="inline-block h-3.5 w-3.5 mr-1 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        Reviewed by {reviewedBy}
      </span>
    )}
  </div>
)}
