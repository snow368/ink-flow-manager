---
<div class="rounded-xl border border-ink-700 bg-ink-900 p-6 sm:p-8">
  <h3 class="text-xl font-bold text-white mb-2">Tattoo Aftercare Email Generator</h3>
  <p class="text-sm text-gray-400 mb-6">Create a professional aftercare message to send your client.</p>

  <div class="space-y-4">
    <div>
      <label class="block text-sm font-medium text-gray-300 mb-1">Client Name</label>
      <input id="ac-name" type="text" placeholder="Alex" class="w-full rounded-lg border border-ink-700 bg-ink-800 px-4 py-2.5 text-white text-sm focus:border-accent-500 focus:outline-none" />
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-300 mb-1">Tattoo Type</label>
      <select id="ac-type" class="w-full rounded-lg border border-ink-700 bg-ink-800 px-4 py-2.5 text-white text-sm focus:border-accent-500 focus:outline-none">
        <option value="new">New Tattoo</option>
        <option value="color">Color Tattoo</option>
        <option value="cover">Cover-Up</option>
        <option value="touch">Touch-Up</option>
        <option value="removal">Removal Session</option>
      </select>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-300 mb-1">Your Studio Name</label>
      <input id="ac-studio" type="text" placeholder="Your Studio" class="w-full rounded-lg border border-ink-700 bg-ink-800 px-4 py-2.5 text-white text-sm focus:border-accent-500 focus:outline-none" />
    </div>
  </div>

  <button id="ac-gen" class="mt-5 w-full rounded-lg bg-accent-500 py-3 text-sm font-semibold text-ink-950 hover:bg-accent-400 transition-colors">
    Generate Aftercare Email
  </button>

  <div id="ac-result" class="mt-6 hidden">
    <div class="rounded-lg border border-ink-700 bg-ink-800 p-4 text-sm text-gray-300 whitespace-pre-wrap font-mono leading-relaxed" id="ac-email"></div>
    <button id="ac-copy" class="mt-3 w-full rounded-lg border border-ink-700 py-2.5 text-sm text-gray-300 hover:border-ink-500 hover:text-white transition-colors">
      Copy to Clipboard
    </button>
    <a href="https://app.inkflow.com/register" class="mt-3 block w-full rounded-lg bg-accent-500 py-2.5 text-center text-sm font-semibold text-ink-950 hover:bg-accent-400 transition-colors">
      Automate Aftercare with InkFlow
    </a>
  </div>
</div>

<script>
const TEMPLATES = {
  new: {
    days: "Day 1-3: Wash gently with antibacterial soap 2-3x daily. Apply thin layer of ointment.\nDay 4-14: Switch to unscented lotion. Keep moisturized but not soaked.\nDay 14+: Your tattoo should be fully healed. Sunscreen is essential!",
    title: "Your New Tattoo — Aftercare Instructions"
  },
  color: {
    days: "Day 1-3: Gently wash with mild soap. Apply aftercare balm.\nDay 4-10: Your color tattoo may feel tight. Keep it moisturized.\nDay 10-21: Colors will settle. Avoid direct sunlight.\nWeek 4+: Your color is fully settled. Show it off!",
    title: "Your Color Tattoo — Aftercare Instructions"
  },
  cover: {
    days: "Day 1-3: Keep bandage on for recommended time. Wash gently.\nDay 4-7: Apply aftercare cream. The area may be tender.\nWeek 2: Healing is well underway. Keep moisturized.\nWeek 3-4: Your cover-up is settling. The old work should be fully concealed.",
    title: "Your Cover-Up — Aftercare Instructions"
  },
  touch: {
    days: "Day 1: The touched-up area is essentially a fresh tattoo.\nDay 2-5: Follow same aftercare as a new tattoo.\nDay 6-14: Keep moisturized, avoid scratching.\nWeek 2+: Your touch-up is healed — looks fresh!",
    title: "Your Touch-Up — Aftercare Instructions"
  },
  removal: {
    days: "Day 1: Apply cold compress if swollen. Keep the area clean.\nDay 2-5: Apply healing ointment as directed. Avoid sun.\nWeek 1-2: Blisters may form — do not pop.\nWeek 3-4: Skin will peel naturally. Keep moisturized.\nNote: Multiple sessions are typically needed.",
    title: "Your Removal Session — Aftercare Instructions"
  }
};

document.getElementById('ac-gen')?.addEventListener('click', () => {
  const name = document.getElementById('ac-name').value || 'there';
  const type = document.getElementById('ac-type').value;
  const studio = document.getElementById('ac-studio').value || 'Your Studio';
  const tpl = TEMPLATES[type] || TEMPLATES.new;

  const email = `Subject: ${tpl.title}\n\nHi ${name},\n\nThank you for visiting ${studio}! Here's how to take care of your tattoo:\n\n${tpl.days}\n\nWhat to Avoid:\n• No swimming or soaking (baths, pools, hot tubs) for 2 weeks\n• No direct sunlight on the area for 3+ weeks\n• No scratching or picking — let it peel naturally\n• Avoid tight clothing over the area\n\nIf you have any concerns, don't hesitate to reach out.\n\nCheers,\n${studio}`;

  document.getElementById('ac-email').textContent = email;
  document.getElementById('ac-result').classList.remove('hidden');
});

document.getElementById('ac-copy')?.addEventListener('click', () => {
  const text = document.getElementById('ac-email').textContent;
  navigator.clipboard?.writeText(text);
  const btn = document.getElementById('ac-copy');
  btn.textContent = 'Copied!';
  setTimeout(() => { btn.textContent = 'Copy to Clipboard'; }, 2000);
});
</script>
