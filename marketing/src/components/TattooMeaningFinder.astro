---
const meanings = {
  rose: { meaning: "Love, beauty, balance, passion", note: "A red rose symbolizes romantic love. A black rose represents loss or rebellion. A rose with thorns shows love with hardship." },
  butterfly: { meaning: "Transformation, freedom, rebirth, beauty", note: "Butterfly tattoos often mark a major life change or personal growth. Popular among all genders." },
  anchor: { meaning: "Stability, hope, strength, staying grounded", note: "Classic sailor tattoo. Often represents a person or belief that keeps you steady." },
  skull: { meaning: "Mortality, life, death, rebellion", note: "A memento mori — reminder that life is short. Often paired with roses or flames." },
  dragon: { meaning: "Power, strength, wisdom, protection", note: "In Eastern culture, dragons are benevolent. In Western, they represent power to be conquered." },
  phoenix: { meaning: "Rebirth, renewal, rising from hardship", note: "Popular for people who have overcome major challenges. Always shown rising from flames." },
  lotus: { meaning: "Enlightenment, purity, spiritual awakening", note: "Sacred in Buddhist and Hindu traditions. Represents rising above challenges." },
  wolf: { meaning: "Loyalty, family, instinct, freedom", note: "Often represents pack loyalty. A lone wolf symbolizes independence." },
  lion: { meaning: "Courage, strength, royalty, leadership", note: "The king of beasts. Often chosen by Leos or those seeking to show inner strength." },
  cross: { meaning: "Faith, protection, sacrifice, belief", note: "One of the most common religious tattoos. Variations include Celtic, Latin, and Orthodox crosses." },
  heart: { meaning: "Love, passion, emotion, life", note: "Classic tattoo. A broken heart represents loss. A sacred heart adds religious meaning." },
  star: { meaning: "Guidance, ambition, hope, destiny", note: "Nautical stars were for finding your way home. Falling stars represent a wish." },
  moon: { meaning: "Mystery, intuition, femininity, cycles", note: "Crescent moon is feminine energy. Full moon represents completeness." },
  sun: { meaning: "Life, energy, power, vitality", note: "Often paired with the moon. Represents yang (masculine) energy in balance." },
  tree: { meaning: "Growth, life, strength, family roots", note: "A tree of life connects heaven and earth. Roots and branches represent family." },
  feather: { meaning: "Freedom, travel, lightness, spirituality", note: "Native American tradition associates feathers with honor and respect." },
  arrow: { meaning: "Focus, determination, moving forward", note: "An arrow must be pulled back to launch forward — overcoming struggle." },
  infinity: { meaning: "Eternity, endless love, limitless potential", note: "Often paired with names or dates in couples tattoos." },
  bird: { meaning: "Freedom, perspective, soul, travel", note: "Flock of birds = freedom. Swallows = returning home. Owls = wisdom." },
  snake: { meaning: "Transformation, healing, wisdom, temptation", note: "Ouroboros (snake eating its tail) = cycle of life. Shedding skin = renewal." },
  eye: { meaning: "Protection, watchfulness, awareness", note: "Evil eye protects against harm. Third eye represents spiritual insight." },
  crown: { meaning: "Authority, victory, self-respect, royalty", note: "You are your own king/queen. Often represents overcoming struggle." },
  key: { meaning: "Opportunity, knowledge, unlocking potential", note: "A key to someone's heart. Skeleton key tattoo = unlocking life's mysteries." },
  compass: { meaning: "Guidance, direction, travel, purpose", note: "North star + compass = never losing your way. Popular among travelers." },
  dreamcatcher: { meaning: "Protection, dreams, filtering negativity", note: "Ojibwe origin. Dreamcatchers filter bad dreams and keep the good." },
  arrowhead: { meaning: "Protection, courage, hunting, survival", note: "Native American symbol of protection and bravery." },
  dagger: { meaning: "Betrayal, protection, sharp wit, danger", note: "A dagger through a heart = betrayal in love. Dagger alone = guardedness." },
  flower: { meaning: "Beauty, life, growth, femininity", note: "Different flowers have different meanings: lily = purity, cherry blossom = impermanence." },
  tiger: { meaning: "Strength, courage, ferocity, protection", note: "In Asian culture, tigers are protective spirits. Often done in Japanese style." },
  koi: { meaning: "Perseverance, strength, luck, overcoming adversity", note: "Koi that swim upstream = overcoming obstacles. In Japanese tradition." },
};

const suggestions = Object.keys(meanings);
---

<div class="rounded-xl border border-ink-700 bg-ink-900 p-6 sm:p-8">
  <h3 class="text-xl font-bold text-white mb-2">Tattoo Meaning Finder</h3>
  <p class="text-sm text-gray-400 mb-6">Search any tattoo design to discover its meaning and symbolism.</p>

  <div class="relative">
    <input id="tm-search" type="text" placeholder="Search a tattoo design (e.g., rose, wolf, dragon)" class="w-full rounded-lg border border-ink-700 bg-ink-800 px-4 py-3 text-white text-sm focus:border-accent-500 focus:outline-none" list="tm-suggestions" />
    <datalist id="tm-suggestions">
      {suggestions.map(s => <option value={s} />)}
    </datalist>
  </div>

  <div id="tm-result" class="mt-6 hidden">
    <div class="rounded-lg bg-ink-800/50 p-5">
      <h4 id="tm-title" class="text-lg font-bold text-white capitalize"></h4>
      <p class="mt-2 text-sm text-gray-300"><span class="font-semibold text-accent-400">Meaning:</span> <span id="tm-meaning"></span></p>
      <p class="mt-1 text-sm text-gray-400"><span class="font-semibold text-gray-300">Note:</span> <span id="tm-note"></span></p>
    </div>
  </div>

  <div id="tm-all" class="mt-6">
    <p class="mb-3 text-sm font-medium text-gray-400">Popular meanings:</p>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
      {suggestions.slice(0, 18).map(s => (
        <button data-symbol={s} class="tm-btn rounded-lg border border-ink-700 px-3 py-2 text-xs text-gray-300 hover:border-accent-500 hover:text-accent-300 transition-colors text-left capitalize">
          {s}
        </button>
      ))}
    </div>
  </div>

  <a href="/find-artist" class="mt-6 block w-full rounded-lg bg-accent-500 py-3 text-center text-sm font-semibold text-ink-950 hover:bg-accent-400 transition-colors">
    Find Your Perfect Tattoo Artist
  </a>
</div>

<script>
  const data = {
    {Object.entries(meanings).map(([k, v]) => `${k}: ${JSON.stringify(v)}`).join(',\n')}
  };

  function showMeaning(key) {
    const item = data[key];
    if (!item) return;
    document.getElementById('tm-title').textContent = key;
    document.getElementById('tm-meaning').textContent = item.meaning;
    document.getElementById('tm-note').textContent = item.note;
    document.getElementById('tm-result').classList.remove('hidden');
  }

  document.getElementById('tm-search')?.addEventListener('input', (e) => {
    const val = e.target.value.trim().toLowerCase();
    if (data[val]) showMeaning(val);
  });

  document.querySelectorAll('.tm-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const symbol = btn.dataset.symbol;
      document.getElementById('tm-search').value = symbol;
      showMeaning(symbol);
    });
  });
</script>
