---
import { TATTOO_CATEGORIES, ALL_MEANINGS } from '../data/tattoo-meanings';

// Build a small lookup of an emoji per category for the chip accents.
const CATEGORY_EMOJI: Record<string, string> = {
  animals: '🐺', flowers: '🌹', mythological: '🐉', geometric: '✶',
  religious: '☥', cultural: '🌀', nature: '🌿', objects: '⚓',
  modern: '✺', birds: '🕊️', zodiac: '✦', insects: '🐝',
  'sea-life': '🌊', time: '⏳', words: '🔤',
};
---

<div class="rounded-2xl border border-ink-800 bg-ink-900/40 p-5 sm:p-7">
  <h3 class="text-xl font-bold text-white">Explore Tattoo Meanings</h3>
  <p class="mt-2 text-sm text-gray-400">Search {ALL_MEANINGS.length} symbols by name, theme, or culture. Filter by category to narrow it down.</p>

  <!-- Search -->
  <div class="relative mt-5">
    <svg class="pointer-events-none absolute left-3 top-1/2 h-5 w-5 -translate-y-1/2 text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="11" cy="11" r="7" /><path d="m21 21-4.3-4.3" />
    </svg>
    <input
      id="tmf-input"
      type="search"
      autocomplete="off"
      placeholder="Try “wave”, “tree of life”, “lion”…"
      class="w-full rounded-xl border border-ink-800 bg-ink-950/60 py-3 pl-10 pr-4 text-sm text-white placeholder-gray-500 outline-none transition-colors focus:border-accent-500/60"
    />
  </div>

  <!-- Category chips -->
  <div id="tmf-chips" class="mt-4 flex flex-wrap gap-2">
    <button type="button" data-cat="all" class="tmf-chip is-active rounded-full border border-accent-500/40 bg-accent-500/10 px-3.5 py-1.5 text-xs font-medium text-accent-300">All ({ALL_MEANINGS.length})</button>
    {TATTOO_CATEGORIES.map((c) => (
      <button type="button" data-cat={c.id} class="tmf-chip rounded-full border border-ink-800 bg-ink-900/40 px-3.5 py-1.5 text-xs font-medium text-gray-400 transition-colors hover:border-accent-500/40 hover:text-accent-300">
        <span class="mr-1">{CATEGORY_EMOJI[c.id] ?? '•'}</span>{c.name}
      </button>
    ))}
  </div>

  <!-- Results -->
  <div id="tmf-results" class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {ALL_MEANINGS.map((m) => (
      <a
        href={`/meaning/${m.slug}`}
        data-category={m.category}
        data-search={`${m.name} ${m.meaning} ${m.slug} ${m.origin ?? ''}`.toLowerCase()}
        class="tmf-card group rounded-xl border border-ink-800 bg-ink-900/30 p-4 transition-all hover:border-accent-500/40"
      >
        <div class="flex items-center gap-2">
          <span class="text-sm font-semibold text-white group-hover:text-accent-300 transition-colors">{m.name}</span>
          <span class="rounded bg-ink-800/60 px-1.5 py-0.5 text-[10px] uppercase tracking-wide text-gray-500">{m.category}</span>
        </div>
        <p class="mt-1.5 line-clamp-2 text-xs leading-relaxed text-gray-500">{m.meaning}</p>
      </a>
    ))}
  </div>

  <p id="tmf-empty" hidden class="mt-6 text-center text-sm text-gray-500">No meanings found — try another word or category.</p>
</div>

<script>
  const input = document.getElementById('tmf-input');
  const chips = document.getElementById('tmf-chips');
  const results = document.getElementById('tmf-results');
  const empty = document.getElementById('tmf-empty');

  if (input && chips && results && empty) {
    const cards = Array.from(results.querySelectorAll<HTMLElement>('.tmf-card'));
    let activeCat = 'all';

    const apply = () => {
      const q = (input as HTMLInputElement).value.trim().toLowerCase();
      let shown = 0;
      for (const card of cards) {
        const cat = card.getAttribute('data-category') || '';
        const search = card.getAttribute('data-search') || '';
        const matchCat = activeCat === 'all' || cat === activeCat;
        const matchQ = q === '' || search.includes(q);
        const visible = matchCat && matchQ;
        card.style.display = visible ? '' : 'none';
        if (visible) shown++;
      }
      empty.hidden = shown !== 0;
    };

    input.addEventListener('input', apply);
    chips.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>('.tmf-chip');
      if (!btn) return;
      chips.querySelectorAll('.tmf-chip').forEach((b) => {
        b.classList.remove('is-active', 'border-accent-500/40', 'bg-accent-500/10', 'text-accent-300');
        b.classList.add('border-ink-800', 'bg-ink-900/40', 'text-gray-400');
      });
      btn.classList.remove('border-ink-800', 'bg-ink-900/40', 'text-gray-400');
      btn.classList.add('is-active', 'border-accent-500/40', 'bg-accent-500/10', 'text-accent-300');
      activeCat = btn.getAttribute('data-cat') || 'all';
      apply();
    });

    apply();
  }
</script>
