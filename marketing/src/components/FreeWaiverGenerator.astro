---
<div class="rounded-xl border border-ink-700 bg-ink-900 p-6 sm:p-8">
  <h3 class="text-xl font-bold text-white mb-2">Free Tattoo Consent Form</h3>
  <p class="text-sm text-gray-400 mb-6">No sign-up required. Fill out, sign, and download your waiver.</p>

  <div id="fw-form" class="space-y-4">
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <label class="block text-sm font-medium text-gray-300 mb-1">Client Name</label>
        <input id="fw-name" type="text" placeholder="Full name" class="w-full rounded-lg border border-ink-700 bg-ink-800 px-4 py-2.5 text-white text-sm focus:border-accent-500 focus:outline-none" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-300 mb-1">Date of Birth</label>
        <input id="fw-dob" type="date" class="w-full rounded-lg border border-ink-700 bg-ink-800 px-4 py-2.5 text-white text-sm focus:border-accent-500 focus:outline-none" />
      </div>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-300 mb-1">Tattoo Description</label>
      <textarea id="fw-design" rows="2" placeholder="Describe your tattoo design, size, and placement" class="w-full rounded-lg border border-ink-700 bg-ink-800 px-4 py-2.5 text-white text-sm focus:border-accent-500 focus:outline-none"></textarea>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-300 mb-1">Studio Name</label>
      <input id="fw-studio" type="text" placeholder="Your tattoo studio" class="w-full rounded-lg border border-ink-700 bg-ink-800 px-4 py-2.5 text-white text-sm focus:border-accent-500 focus:outline-none" />
    </div>

    <div class="rounded-lg border border-ink-700 bg-ink-800/50 p-4">
      <p class="mb-3 text-sm font-medium text-white">Health Declaration</p>
      <div class="space-y-2 text-sm text-gray-400">
        <label class="flex items-center gap-3">
          <input type="checkbox" id="fw-health1" class="accent-accent-500" /> Are you pregnant or nursing?
        </label>
        <label class="flex items-center gap-3">
          <input type="checkbox" id="fw-health2" class="accent-accent-500" /> Do you have diabetes, heart disease, or a weakened immune system?
        </label>
        <label class="flex items-center gap-3">
          <input type="checkbox" id="fw-health3" class="accent-accent-500" /> Are you allergic to latex or any metals?
        </label>
        <label class="flex items-center gap-3">
          <input type="checkbox" id="fw-health4" class="accent-accent-500" /> Do you have any skin conditions (eczema, psoriasis) near the tattoo area?
        </label>
        <label class="flex items-center gap-3">
          <input type="checkbox" id="fw-health5" class="accent-accent-500" /> Are you currently on blood-thinning medication?
        </label>
      </div>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-300 mb-2">Signature</label>
      <div class="rounded-lg border border-ink-700 bg-ink-950 overflow-hidden">
        <canvas id="fw-canvas" width="500" height="150" class="w-full cursor-crosshair"></canvas>
      </div>
      <button id="fw-clear" type="button" class="mt-1 text-xs text-gray-500 hover:text-gray-300">Clear signature</button>
    </div>
  </div>

  <div class="mt-6 space-y-3">
    <button id="fw-submit" class="w-full rounded-lg bg-accent-500 py-3 text-sm font-semibold text-ink-950 hover:bg-accent-400 transition-colors">
      Generate Waiver PDF
    </button>
  </div>

  <div id="fw-result" class="mt-6 hidden">
    <div class="rounded-lg border border-accent-500/20 bg-accent-500/5 p-4 text-center">
      <p class="text-accent-400 font-semibold">✓ Waiver Generated</p>
      <p class="mt-1 text-sm text-gray-400">Your consent form is ready.</p>
      <button id="fw-print" class="mt-4 w-full rounded-lg border border-ink-700 py-2.5 text-sm text-gray-300 hover:border-ink-500 transition-colors">
        Print / Save as PDF
      </button>
    </div>
    <p class="mt-3 text-center text-xs text-gray-600">Powered by <a href="/" class="text-accent-400 hover:underline">InkFlow</a></p>
    <a href="https://app.inkflow.com/register" class="mt-4 block w-full rounded-lg bg-accent-500 py-3 text-center text-sm font-semibold text-ink-950 hover:bg-accent-400 transition-colors">
      Save Waivers & Manage Clients — Try InkFlow Free
    </a>
  </div>
</div>

<script>
  const canvas = document.getElementById('fw-canvas');
  const ctx = canvas.getContext('2d');
  let drawing = false;

  function resizeCanvas() {
    const rect = canvas.parentElement.getBoundingClientRect();
    canvas.width = rect.width || 500;
  }
  resizeCanvas();
  window.addEventListener('resize', resizeCanvas);

  function getPos(e) {
    const rect = canvas.getBoundingClientRect();
    const x = (e.clientX - rect.left) * (canvas.width / rect.width);
    const y = (e.clientY - rect.top) * (canvas.height / rect.height);
    return { x, y };
  }

  canvas.addEventListener('mousedown', () => drawing = true);
  canvas.addEventListener('mouseup', () => drawing = false);
  canvas.addEventListener('mousemove', (e) => {
    if (!drawing) return;
    const pos = getPos(e);
    ctx.fillStyle = '#fff';
    ctx.beginPath();
    ctx.arc(pos.x, pos.y, 2, 0, Math.PI * 2);
    ctx.fill();
  });

  document.getElementById('fw-clear')?.addEventListener('click', () => {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
  });

  document.getElementById('fw-submit')?.addEventListener('click', () => {
    const name = document.getElementById('fw-name').value || 'Client';
    document.getElementById('fw-result').classList.remove('hidden');
    document.getElementById('fw-submit').textContent = '✓ Generated';
  });

  document.getElementById('fw-print')?.addEventListener('click', () => {
    const name = document.getElementById('fw-name').value || 'Client';
    const dob = document.getElementById('fw-dob').value || '—';
    const design = document.getElementById('fw-design').value || '—';
    const studio = document.getElementById('fw-studio').value || '—';
    const date = new Date().toLocaleDateString();
    const sig = canvas.toDataURL();

    const win = window.open('', '', 'width=600,height=800');
    win.document.write(`
      <html><head><title>Waiver - ${name}</title>
      <style>
        body { font-family: sans-serif; padding: 40px; max-width: 600px; margin: 0 auto; }
        h1 { font-size: 20px; margin-bottom: 4px; }
        .meta { color: #666; font-size: 13px; margin-bottom: 20px; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
        td { padding: 8px 4px; border-bottom: 1px solid #ddd; font-size: 14px; }
        td:first-child { font-weight: 600; width: 120px; }
        .sig { margin-top: 20px; }
        .sig img { max-width: 300px; border: 1px solid #ddd; display: block; margin-top: 8px; }
        .footer { margin-top: 30px; font-size: 11px; color: #999; text-align: center; }
      </style></head>
      <body>
        <h1>Tattoo Consent Form</h1>
        <p class="meta">Generated on ${date}</p>
        <table>
          <tr><td>Client</td><td>${name}</td></tr>
          <tr><td>DOB</td><td>${dob}</td></tr>
          <tr><td>Studio</td><td>${studio}</td></tr>
          <tr><td>Design</td><td>${design}</td></tr>
        </table>
        <p style="font-size:13px">I confirm that the above health information is accurate. I understand the risks and consent to the tattoo procedure.</p>
        <div class="sig">
          <p style="font-size:13px;font-weight:600">Signature:</p>
          <img src="${sig}" alt="signature" />
        </div>
        <p class="footer">Powered by InkFlow — inkflow.com</p>
        <script>window.print();</script>
      </body></html>
    `);
    win.document.close();
  });
</script>
