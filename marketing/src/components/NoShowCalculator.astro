---
<div class="rounded-xl border border-ink-700 bg-ink-900 p-6 sm:p-8">
  <h3 class="text-xl font-bold text-white mb-2">No-Show Cost Calculator</h3>
  <p class="text-sm text-gray-400 mb-6">See how much no-shows are costing your studio.</p>

  <div class="space-y-4">
    <div>
      <label class="block text-sm font-medium text-gray-300 mb-1">Average session price ($)</label>
      <input id="ns-price" type="number" value="300" min="50" max="2000" class="w-full rounded-lg border border-ink-700 bg-ink-800 px-4 py-2.5 text-white text-sm focus:border-accent-500 focus:outline-none" />
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-300 mb-1">No-shows per week</label>
      <input id="ns-count" type="number" value="3" min="0" max="50" class="w-full rounded-lg border border-ink-700 bg-ink-800 px-4 py-2.5 text-white text-sm focus:border-accent-500 focus:outline-none" />
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-300 mb-1">Number of artists</label>
      <input id="ns-artists" type="number" value="3" min="1" max="50" class="w-full rounded-lg border border-ink-700 bg-ink-800 px-4 py-2.5 text-white text-sm focus:border-accent-500 focus:outline-none" />
    </div>
  </div>

  <button id="ns-calc-btn" class="mt-6 w-full rounded-lg bg-accent-500 py-3 text-sm font-semibold text-ink-950 hover:bg-accent-400 transition-colors">
    Calculate Your Loss
  </button>

  <div id="ns-result" class="mt-6 hidden">
    <div class="rounded-lg bg-ink-800/50 p-4 text-center">
      <p class="text-sm text-gray-400">Monthly loss</p>
      <p id="ns-monthly" class="text-3xl font-bold text-red-400">$0</p>
      <p class="text-sm text-gray-400 mt-2">Yearly loss</p>
      <p id="ns-yearly" class="text-3xl font-bold text-red-400">$0</p>
      <p id="ns-save" class="mt-3 text-sm text-accent-400"></p>
    </div>
    <a href="https://app.inkflow.com/register" class="mt-4 block w-full rounded-lg bg-accent-500 py-3 text-center text-sm font-semibold text-ink-950 hover:bg-accent-400 transition-colors">
      Reduce No-Shows with InkFlow
    </a>
  </div>
</div>

<script>
  document.getElementById('ns-calc-btn')?.addEventListener('click', () => {
    const price = parseInt(document.getElementById('ns-price').value) || 300;
    const count = parseInt(document.getElementById('ns-count').value) || 3;
    const artists = parseInt(document.getElementById('ns-artists').value) || 3;

    const weekly = price * count * artists;
    const monthly = weekly * 4.33;
    const yearly = monthly * 12;
    const saved80 = (yearly * 0.8).toFixed(0);
    const saved50 = (yearly * 0.5).toFixed(0);

    document.getElementById('ns-monthly').textContent = '$' + Math.round(monthly).toLocaleString();
    document.getElementById('ns-yearly').textContent = '$' + Math.round(yearly).toLocaleString();
    document.getElementById('ns-save').innerHTML = 'InkFlow can save you <strong>$' + Number(saved80).toLocaleString() + '</strong> per year (80% no-show reduction)';
    document.getElementById('ns-result').classList.remove('hidden');
  });
</script>
