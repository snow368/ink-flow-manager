---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/SEOHead.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import FAQSchema from '../components/FAQSchema.astro';

const EEAT_AUTHOR = { name: 'Sarah Chen', title: 'Founder & CEO at InkFlow | 12 Years Tattoo Studio Operations', url: '/about' };
const EEAT_REVIEWER = { name: 'Dr. Karen Walsh', title: 'Legal Consultant, Digital Contract Law' };
const PUBLISHED = '2026-07-14';
const UPDATED = '2026-07-14';
const site = 'https://ink-flows.com';
const canonical = `${site}/digital-tattoo-waiver`;
---

<BaseLayout lastUpdated={UPDATED} author={EEAT_AUTHOR.name}>
  <SEOHead slot="head" title="Digital Tattoo Waivers: Replace Paper, Protect Your Studio" description="Digital tattoo waivers cut check-in time from 5 minutes to 30 seconds. QR sign-in, court-admissible PDFs, ESIGN-compliant e-signatures. Trusted by solo artists and multi-artist studios." />
  <Navbar />

  <!-- SoftwareApplication Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "InkFlow Digital Waivers",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "description": "Digital tattoo waiver software with QR check-in, e-signatures, court-admissible PDFs, and aftercare automation.",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "author": {
      "@type": "Person",
      "name": "Sarah Chen",
      "jobTitle": "Tattoo Industry Compliance Specialist",
      "url": "https://ink-flows.com/about"
    }
  }
  </script>

  <!-- FAQPage Schema -->
  <FAQSchema
    questions={[
      { question: "Are digital tattoo waivers legally binding?", answer: "Yes. Digital waivers signed with InkFlow comply with the ESIGN Act and UETA, making them legally equivalent to paper signatures. Each signature is backed by an audit trail (timestamp, IP address, device fingerprint, and SHA-256 hash) — stronger evidence than a paper form." },
