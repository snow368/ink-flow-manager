const LAYOUT_GROUPS = [
  { key: 'classic', name: 'Classic Scroll', icon: '📜', desc: 'Full single-page scrolling layout — hero, services, gallery, map. Clean and professional.' },
  { key: 'hero-grid', name: 'Gallery Grid', icon: '🖼️', desc: 'Full-screen hero image with masonry photo grid. Best for visual portfolios.' },
  { key: 'link-bio', name: 'Link in Bio', icon: '🔗', desc: 'Linktree-style page with buttons. Perfect for Instagram bio link.' },
  { key: 'studio-roster', name: 'Artist Roster', icon: '👥', desc: 'Multi-artist studio showcase with artist cards. Great for shops with multiple tattooists.' },
  { key: 'cards', name: 'Card Style', icon: '🃏', desc: 'Everything in floating cards with shadows. Modern app-like feel.' },
  { key: 'split', name: 'Split Screen', icon: '↔️', desc: 'Image and text side by side. Bold, editorial layouts.' },
  { key: 'editorial', name: 'Magazine', icon: '📰', desc: 'Full-bleed images with story-like text. Large, dramatic typography.' },
  { key: 'minimal-bar', name: 'Sticky Bar', icon: '📱', desc: 'Minimal page with sticky bottom action bar. Call, book, and IG in one tap.' },
];
---

<BaseLayout>
  <SEOHead slot="head" title="41 Tattoo Website Templates — InkFlow" description="Choose from 41 tattoo studio website templates across 8 unique layouts. Each with multiple color themes. Mobile-friendly, SEO-optimized, ready in minutes." />
  <Navbar />

  <section class="pt-24 pb-12 sm:pt-32">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold text-accent-400 mb-3">TEMPLATES</p>
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">8 Layouts · 41 Color Themes</h1>
      <p class="mt-4 text-lg text-gray-400 max-w-2xl mx-auto">Choose a layout style, then pick your color theme. Every combination is mobile-friendly, SEO-optimized, and ready in minutes.</p>
    </div>
  </section>

  {LAYOUT_GROUPS.map(group => {
    const groupTemplates = TEMPLATES.filter(t => t.layout === group.key);
    return (
    <section class="border-t border-ink-800/50 py-16">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="flex items-start gap-4 mb-8">
          <span class="text-3xl">{group.icon}</span>
          <div>
            <h2 class="text-2xl font-bold text-white">{group.name}</h2>
            <p class="text-sm text-gray-400 mt-1">{group.desc}</p>
          </div>
        </div>

        <!-- Layout preview card (big) -->
        <div class="rounded-xl border border-ink-700 bg-ink-900/50 overflow-hidden mb-6">
          <div class="h-64 sm:h-96 bg-ink-800/50 flex items-center justify-center">
            <iframe src={`https://ink-flow-api.snow368.workers.dev/api/template-preview/${groupTemplates[0].key}`} class="w-full h-full" loading="lazy" title={`${group.name} preview`} style="pointer-events:none;border:none;" />
          </div>
        </div>

        <!-- Color themes row -->
        <div class="flex flex-wrap gap-3">
          {groupTemplates.map(t => (
            <div class="color-swatch group relative flex items-center gap-2 rounded-xl border border-ink-700 bg-ink-900/30 px-4 py-3 hover:border-accent-500/50 hover:bg-ink-800/50 transition-all min-w-[140px] cursor-pointer" data-key={t.key} data-tier={t.tier} data-name={t.name} style={`border-color: ${t.tier === 'plus' ? '#f59e0b' : t.tier === 'pro' ? 'rgb(163 58 58)' : 'rgb(34 197 94)'}40`}>
              <div class="w-5 h-5 rounded-full shrink-0" style={`background: ${['minimal','studio','traditional','brutalist'].includes(t.key) ? '#fff' : '#1a1a1a'}`}></div>
              <p class="text-sm font-medium text-white group-hover:text-accent-400 transition-colors">{t.name}</p>
              <span class="text-[10px] font-medium" style={`color: ${t.tier === 'plus' ? '#f59e0b' : t.tier === 'pro' ? 'rgb(163 58 58)' : 'rgb(34 197 94)'}`}>{t.tier === 'free' ? '' : t.tier === 'pro' ? 'Pro' : '+'}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
    );
  })}

  <!-- Get Started Form -->
  <section class="border-t border-ink-800/50 py-16" id="get-started">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold text-white sm:text-3xl">Create Your Website</h2>
      <p class="mt-3 text-gray-400">Fill in your info. We'll generate your site instantly. Pay only when you're happy.</p>
      <div id="selectedTemplate" class="mt-4 text-sm text-accent-400"></div>

      <!-- Step 1: Info Form -->
      <div id="stepForm" class="mt-8 max-w-md mx-auto text-left">
        <div class="space-y-4">
          <div>
            <label class="block text-sm text-gray-400 mb-1">Email</label>
            <input type="email" id="fieldEmail" placeholder="your@email.com" class="w-full px-4 py-2.5 rounded-lg border border-ink-700 bg-ink-900 text-white text-sm focus:border-accent-500 outline-none">
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Studio Name</label>
            <input type="text" id="fieldName" placeholder="Your Tattoo Studio" class="w-full px-4 py-2.5 rounded-lg border border-ink-700 bg-ink-900 text-white text-sm focus:border-accent-500 outline-none">
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Instagram Handle (optional)</label>
            <input type="text" id="fieldIG" placeholder="@yourstudio" class="w-full px-4 py-2.5 rounded-lg border border-ink-700 bg-ink-900 text-white text-sm focus:border-accent-500 outline-none">
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Bio (optional)</label>
            <textarea id="fieldBio" rows="2" placeholder="Tell clients about your studio..." class="w-full px-4 py-2.5 rounded-lg border border-ink-700 bg-ink-900 text-white text-sm focus:border-accent-500 outline-none"></textarea>
          </div>
          <button onclick="generateSite()" id="generateBtn" class="w-full py-3 rounded-lg bg-accent-500 text-white font-semibold hover:bg-accent-400 transition-colors">Generate Free Preview →</button>
          <p class="text-xs text-gray-600 text-center" id="pricingHint">Free preview. Basic ($9.99/yr) gets all free templates. Pro ($19.99/yr) unlocks all 41.</p>
        </div>
      </div>

      <!-- Step 2: Preview -->
      <div id="stepPreview" class="mt-8 hidden">
        <div class="rounded-xl border border-ink-700 overflow-hidden">
          <iframe id="previewFrame" class="w-full h-[500px]" style="pointer-events:none"></iframe>
        </div>
        <div class="mt-6 flex gap-4 justify-center">
          <button onclick="publishSite()" class="px-8 py-3 rounded-lg bg-accent-500 text-white font-semibold hover:bg-accent-400 transition-colors">Publish — $9.99/yr</button>
          <button onclick="publishSitePro()" class="px-8 py-3 rounded-lg bg-green-600 text-white font-semibold hover:bg-green-500 transition-colors">Publish Pro — $19.99/yr</button>
        </div>
        <p class="mt-3 text-xs text-gray-600">Secure payment via Stripe · Cancel anytime</p>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script is:inline>
  let selectedTemplate = null;
  let selectedTier = 'free';

  window.selectTemplate = function(key, name, tier) {
    selectedTemplate = key;
    selectedTier = tier || 'free';
    document.getElementById('selectedTemplate').textContent = '✓ Selected: ' + name;

    // Highlight selected swatch
    document.querySelectorAll('.color-swatch').forEach(el => {
      el.style.borderColor = '';
      el.style.background = '';
    });
    const swatch = document.querySelector(`.color-swatch[data-key="${key}"]`);
    if (swatch) {
      swatch.style.borderColor = '#06b6d4';
      swatch.style.background = '#06b6d415';
    }

    // Update the preview iframe in the same layout group
    const groupSection = swatch?.closest('section');
    const iframe = groupSection?.querySelector('iframe');
    if (iframe) {
      const newSrc = iframe.src.replace(/\/api\/template-preview\/[^\/]+/, '/api/template-preview/' + key);
      iframe.src = newSrc;
    }

    document.getElementById('get-started').scrollIntoView({ behavior: 'smooth' });
  };

  document.addEventListener('click', function(e) {
    const swatch = e.target.closest('.color-swatch');
    if (swatch) {
      const key = swatch.dataset.key;
      const name = swatch.dataset.name;
      const tier = swatch.dataset.tier;
      window.selectTemplate(key, name, tier);
    }
  });
</script>

  async function generateSite() {
    const email = document.getElementById('fieldEmail').value.trim();
    const name = document.getElementById('fieldName').value.trim();
    const ig = document.getElementById('fieldIG').value.trim();
    const bio = document.getElementById('fieldBio').value.trim();
    if (!email || !name) { alert('Email and Studio Name are required'); return; }
    if (!selectedTemplate) { alert('Please select a template first'); return; }

    const btn = document.getElementById('generateBtn');
    btn.disabled = true; btn.textContent = 'Generating...';

    try {
      // Register via API
      const res = await fetch('https://ink-flow-api.snow368.workers.dev/api/auth/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, name, studioName: name, plan: selectedTier === 'free' ? 'website_basic' : 'website_pro' })
      });
      const data = await res.json();
      if (!res.ok) { alert('Error: ' + (data.error || 'Registration failed')); btn.disabled = false; btn.textContent = 'Generate Free Preview →'; return; }

      // Generate preview via template-preview API
      const previewUrl = 'https://ink-flow-api.snow368.workers.dev/api/template-preview/' + selectedTemplate;
      document.getElementById('previewFrame').src = previewUrl;
      document.getElementById('stepForm').classList.add('hidden');
      document.getElementById('stepPreview').classList.remove('hidden');
    } catch (e) {
      alert('Network error. Please try again.');
      btn.disabled = false; btn.textContent = 'Generate Free Preview →';
    }
  }

  function publishSite() {
    const plan = 'website_basic';
    window.open('https://app.ink-flows.com/register?plan=' + plan + '&template=' + selectedTemplate, '_blank');
  }

  function publishSitePro() {
    const plan = 'website_pro';
    window.open('https://app.ink-flows.com/register?plan=' + plan + '&template=' + selectedTemplate, '_blank');
  }
</script>
