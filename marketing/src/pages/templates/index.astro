---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const TEMPLATES = [
  // === classic ===
  { name: 'Minimal', key: 'minimal', tier: 'free', layout: 'classic', desc: 'Clean single-page scroll. Perfect for solo artists.' },
  { name: 'Vintage', key: 'vintage', tier: 'free', layout: 'classic', desc: 'Warm retro scroll. Great for traditional shops.' },
  { name: 'Moody', key: 'moody', tier: 'free', layout: 'classic', desc: 'Dark dramatic scroll. Bold and atmospheric.' },
  { name: 'Desert', key: 'desert', tier: 'free', layout: 'classic', desc: 'Warm earthy tones. Relaxed southwest vibe.' },
  { name: 'Retro Wave', key: 'retro-wave', tier: 'plus', layout: 'classic', desc: '80s neon synthwave. Loud and proud.' },
  { name: 'Nordic', key: 'nordic', tier: 'free', layout: 'classic', desc: 'Cool minimal Scandi. Clean and modern.' },

  // === hero-grid ===
  { name: 'Studio', key: 'studio', tier: 'pro', layout: 'hero-grid', desc: 'Full-screen hero + big photo grid. Gallery-first.' },
  { name: 'Coastal', key: 'coastal', tier: 'plus', layout: 'hero-grid', desc: 'Light beachy gallery. Bright and airy.' },
  { name: 'Arctic', key: 'arctic', tier: 'free', layout: 'hero-grid', desc: 'Ice blue gallery. Cool and minimalist.' },
  { name: 'Watercolor', key: 'watercolor', tier: 'plus', layout: 'hero-grid', desc: 'Soft pastel gallery. Artistic and gentle.' },
  { name: 'Lavender', key: 'lavender', tier: 'free', layout: 'hero-grid', desc: 'Purple tones gallery. Soft and elegant.' },

  // === link-bio ===
  { name: 'Brutalist', key: 'brutalist', tier: 'pro', layout: 'link-bio', desc: 'Bold black & white link page. IG bio perfect.' },
  { name: 'Tribal', key: 'tribal', tier: 'free', layout: 'link-bio', desc: 'Black & grey link page. Clean and sharp.' },
  { name: 'Punk', key: 'punk', tier: 'pro', layout: 'link-bio', desc: 'High-contrast yellow link page. Street edge.' },
  { name: 'Maori', key: 'maori', tier: 'free', layout: 'link-bio', desc: 'Red & black link page. Tribal energy.' },
  { name: 'Monochrome', key: 'monochrome', tier: 'free', layout: 'link-bio', desc: 'Greyscale link page. Timeless minimal.' },

  // === studio-roster ===
  { name: 'Traditional', key: 'traditional', tier: 'free', layout: 'studio-roster', desc: 'Bold red roster. Classic American shop feel.' },
  { name: 'Nature', key: 'nature', tier: 'pro', layout: 'studio-roster', desc: 'Forest green roster. Earthy and grounded.' },
  { name: 'Woodcut', key: 'woodcut', tier: 'plus', layout: 'studio-roster', desc: 'Dark print roster. Vintage engraving style.' },
  { name: 'Botanical', key: 'botanical', tier: 'free', layout: 'studio-roster', desc: 'Sage green roster. Fresh and natural.' },
  { name: 'Tropical', key: 'tropical', tier: 'pro', layout: 'studio-roster', desc: 'Coral & teal roster. Island vacation vibe.' },

  // === cards ===
  { name: 'Edgy', key: 'edgy', tier: 'pro', layout: 'cards', desc: 'Neon pink cards. Modern streetwear energy.' },
  { name: 'Neon', key: 'neon', tier: 'pro', layout: 'cards', desc: 'Cyan glow cards. Cyberpunk aesthetic.' },
  { name: 'Metallic', key: 'metallic', tier: 'plus', layout: 'cards', desc: 'Silver chrome cards. Industrial sleek.' },
  { name: 'Cyberpunk', key: 'cyberpunk', tier: 'pro', layout: 'cards', desc: 'Neon magenta cards. Futuristic bold.' },
  { name: 'New School', key: 'new-school', tier: 'pro', layout: 'cards', desc: 'Cartoon bright cards. Fun and colorful.' },

  // === split ===
  { name: 'Royal', key: 'royal', tier: 'pro', layout: 'split', desc: 'Purple & gold split. Luxurious feel.' },
  { name: 'Midnight', key: 'midnight', tier: 'free', layout: 'split', desc: 'Deep blue split. Night sky elegance.' },
  { name: 'Celestial', key: 'celestial', tier: 'plus', layout: 'split', desc: 'Gold on midnight split. Cosmic luxury.' },
  { name: 'Sunset', key: 'sunset', tier: 'pro', layout: 'split', desc: 'Orange glow split. Warm sunset drama.' },
  { name: 'Chicano', key: 'chicano', tier: 'pro', layout: 'split', desc: 'Brown & gold split. Chicano pride.' },

  // === editorial ===
  { name: 'Gothic', key: 'gothic', tier: 'plus', layout: 'editorial', desc: 'Ornate dark editorial. Moody magazine feel.' },
  { name: 'Japanese', key: 'japanese', tier: 'pro', layout: 'editorial', desc: 'Irezumi red editorial. Traditional Japanese.' },
  { name: 'Steampunk', key: 'steampunk', tier: 'plus', layout: 'editorial', desc: 'Brass & bronze editorial. Victorian industrial.' },
  { name: 'Neonoir', key: 'neonoir', tier: 'pro', layout: 'editorial', desc: 'Red noir editorial. Dark film aesthetic.' },
  { name: 'Halloween', key: 'halloween', tier: 'free', layout: 'editorial', desc: 'Orange & black editorial. Spooky style.' },

  // === minimal-bar ===
  { name: 'Industrial', key: 'industrial', tier: 'plus', layout: 'minimal-bar', desc: 'Steel bar layout. Factory rugged.' },
  { name: 'Urban', key: 'urban', tier: 'plus', layout: 'minimal-bar', desc: 'Graffiti bar layout. City street energy.' },
  { name: 'Sakura', key: 'sakura', tier: 'pro', layout: 'minimal-bar', desc: 'Cherry blossom bar. Delicate and feminine.' },
  { name: 'Biomechanical', key: 'biomechanical', tier: 'pro', layout: 'minimal-bar', desc: 'Metallic red bar. Sci-fi organic.' },
  { name: 'Trash Polka', key: 'trash-polka', tier: 'plus', layout: 'minimal-bar', desc: 'Collage chaos bar. Surreal art.' },
