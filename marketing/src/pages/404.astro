---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/SEOHead.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <SEOHead
    slot="head"
    title="Page Not Found — InkFlow"
    description="The page you're looking for doesn't exist. Explore tattoo meanings, free studio tools, or head back to InkFlow's homepage."
    appSchema={false}
  />
  <Navbar />

  <section class="flex min-h-[60vh] items-center justify-center px-4 py-24">
    <div class="mx-auto max-w-xl text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-accent-400">404</p>
      <h1 class="mt-3 text-4xl font-extrabold text-white sm:text-5xl">This page wandered off</h1>
      <p class="mt-4 text-lg text-gray-400">
        The page you're looking for doesn't exist or may have moved. Let's get you back on track.
      </p>

      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href="/"
          class="inline-flex items-center justify-center rounded-xl bg-accent-500 px-6 py-3 text-sm font-semibold text-ink-950 transition hover:bg-accent-400"
        >
          Back to homepage
        </a>
        <a
          href="/meaning"
          class="inline-flex items-center justify-center rounded-xl border border-ink-700 px-6 py-3 text-sm font-semibold text-white transition hover:border-ink-500"
        >
          Browse tattoo meanings
        </a>
      </div>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-gray-500">
        <a href="/free-tools/tattoo-meaning-finder" class="hover:text-accent-400 hover:underline">Meaning Finder</a>
        <a href="/free-tools/tattoo-price-calculator" class="hover:text-accent-400 hover:underline">Price Calculator</a>
        <a href="/blog" class="hover:text-accent-400 hover:underline">Studio Blog</a>
        <a href="/contact" class="hover:text-accent-400 hover:underline">Contact</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
