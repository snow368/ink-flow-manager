---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout>
  <SEOHead slot="head" title="InkFlow vs Booksy for Tattoo Studios — Comparison 2026" description="Compare InkFlow vs Booksy for tattoo studios. Booksy works for salons — InkFlow is built for tattoo shops with waivers, aftercare, and commission tracking." />
  <Navbar />

  <section class="pt-24 pb-16 sm:pt-32">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">InkFlow vs Booksy for Tattoo Studios</h1>
      <p class="mt-4 text-lg text-gray-400">Booksy is a general booking platform. InkFlow is purpose-built for tattoo studios.</p>
    </div>
  </section>

  <section class="border-t border-ink-800/50 py-8">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-xl border border-accent-500/20 bg-accent-500/5 p-6">
        <h2 class="text-lg font-bold text-white">Quick Verdict</h2>
        <p class="mt-2 text-sm text-gray-400">If you need a simple booking app for a solo shop, Booksy works. If you need deposit-based scheduling, digital waivers, commission tracking, and aftercare automation — choose InkFlow.</p>
      </div>
    </div>
  </section>

  <section class="py-12 text-center border-t border-ink-800/50">
    <h2 class="text-2xl font-bold text-white">Try InkFlow Free</h2>
    <a href="https://app.inkflow.com/register" class="mt-6 inline-block rounded-lg bg-accent-500 px-8 py-3.5 text-base font-semibold text-ink-950 hover:bg-accent-400 transition-all">Start Free Trial</a>
  </section>
  <Footer />
</BaseLayout>
