---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import FAQSchema from '../../components/FAQSchema.astro';
import AftercareEmailGenerator from '../../components/AftercareEmailGenerator.astro';
---

<BaseLayout>
  <SEOHead slot="head" title="Free Tattoo Aftercare Email Template Generator | InkFlow" description="Create professional tattoo aftercare email templates for your studio. Customize and send in minutes. Free tool, no signup needed." />
  <FAQSchema questions={[
    { question: "Is the aftercare email generator free?", answer: "Yes. Generate unlimited aftercare email templates for free. No account or signup required." },
    { question: "Can I customize the generated emails?", answer: "Yes. You can edit the generated template before copying. Adjust the tone, add studio-specific details, or modify the instructions." },
    { question: "What's included in the aftercare email?", answer: "Basic aftercare instructions covering washing, moisturizing, sun protection, and healing timeline. The template can be customized for different tattoo types." },
    { question: "How do I send the generated email?", answer: "Copy the generated template and paste into your email client, SMS, or DM. For automated sending, upgrade to InkFlow's aftercare automation." },
  ]} />
  <Navbar />


  <!-- HowTo Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
  "name": "Tattoo Aftercare Email Template Generator",
  "description": "Generate a personalized aftercare email template for tattoo clients. Choose tone and customize.",
  "step": [
    {
      "@type": "HowToStep",
      "position": 1,
      "name": "Enter client details",
      "text": "Fill in client name and tattoo type."
    },
    {
      "@type": "HowToStep",
      "position": 2,
      "name": "Select email tone",
      "text": "Choose professional, friendly, or detailed tone."
    },
    {
      "@type": "HowToStep",
      "position": 3,
      "name": "Copy the template",
      "text": "Generated instantly. Copy to clipboard."
    },
    {
      "@type": "HowToStep",
      "position": 4,
      "name": "Send to client",
      "text": "Paste into email or SMS and send."
    }
  ]
})} />
  <!-- HERO -->
  <section class="pt-24 pb-12 sm:pt-32">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold text-accent-400 mb-3">FREE TOOL</p>
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Tattoo Aftercare Email Template Generator</h1>
      <p class="mt-4 text-lg text-gray-400">Generate a personalized aftercare message for every client. Enter their name and tattoo type — copy the template and send in 10 seconds.</p>
    </div>
  </section>

  <!-- TOOL -->
  <section class="pb-12">
    <div class="mx-auto max-w-xl px-4 sm:px-6 lg:px-8">
      <AftercareEmailGenerator />
    </div>
  </section>

  <!-- PROBLEM: Why aftercare matters -->
  <section class="border-t border-ink-800/50 py-16 bg-ink-900/20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white text-center">Why Aftercare Communication Matters</h2>
      <div class="mt-8 space-y-4">
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5"><h3 class="text-white font-semibold text-sm">Most artists forget to send aftercare instructions after the first session.</h3><p class="mt-1 text-sm text-gray-400">You explain aftercare in person on day 1, but follow-ups drop to under 15% by day 14. A written template ensures clients have the instructions when they need them most — when they get home.</p></div>
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5"><h3 class="text-white font-semibold text-sm">Poor aftercare leads to healing issues and unhappy clients.</h3><p class="mt-1 text-sm text-gray-400">Clients who don't receive clear instructions are more likely to develop infections, pick at scabs, or use wrong products. One follow-up message can prevent all of this.</p></div>
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5"><h3 class="text-white font-semibold text-sm">You're missing out on healed photos and reviews.</h3><p class="mt-1 text-sm text-gray-400">A well-timed aftercare message at week 4 can request a healed photo. Studios using automated aftercare see 40% more healed photo submissions and 2x more reviews.</p></div>
      </div>
    </div>
  </section>

  <!-- TEMPLATE BREAKDOWN -->
  <section class="border-t border-ink-800/50 py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white text-center">What Your Aftercare Message Should Include</h2>
      <p class="mt-3 text-center text-gray-400">A complete aftercare sequence covers the full healing timeline. Here's what each phase should address.</p>
      <div class="mt-10 space-y-8">
        <div class="grid gap-6 md:grid-cols-2">
          <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5">
            <h3 class="text-white font-semibold">Immediate (Day 1)</h3>
            <ul class="mt-2 space-y-1 text-sm text-gray-400">
              <li>✓ Keep bandage on for 2-4 hours</li>
              <li>✓ Wash with antibacterial soap</li>
              <li>✓ Pat dry with paper towel</li>
              <li>✓ Apply thin layer of ointment</li>
              <li>✓ Don't submerge in water</li>
            </ul>
          </div>
          <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5">
            <h3 class="text-white font-semibold">First Week (Days 2-7)</h3>
            <ul class="mt-2 space-y-1 text-sm text-gray-400">
              <li>✓ Wash 2-3 times daily</li>
              <li>✓ Moisturize after washing</li>
              <li>✓ Don't pick at peeling skin</li>
              <li>✓ Avoid tight clothing over tattoo</li>
              <li>✓ No direct sunlight</li>
            </ul>
          </div>
          <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5">
            <h3 class="text-white font-semibold">Week 2-3</h3>
            <ul class="mt-2 space-y-1 text-sm text-gray-400">
              <li>✓ Switch to unscented lotion</li>
              <li>✓ Continue sun protection</li>
              <li>✓ Avoid swimming/hot tubs</li>
              <li>✓ Watch for signs of infection</li>
            </ul>
          </div>
          <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5">
            <h3 class="text-white font-semibold">Week 4+</h3>
            <ul class="mt-2 space-y-1 text-sm text-gray-400">
              <li>✓ Tattoo should be fully healed</li>
              <li>✓ Send a healed photo request</li>
              <li>✓ Leave a Google review</li>
              <li>✓ Schedule touch-up if needed</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- COMPARISON: Free vs Automated -->
  <section class="border-t border-ink-800/50 py-16 bg-ink-900/20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white text-center">Free Generator vs InkFlow Aftercare Automation</h2>
      <p class="mt-3 text-center text-gray-400">The generator gives you a template to copy. Automation sends messages for you — on schedule, every time.</p>
      <div class="mt-8 overflow-hidden rounded-xl border border-ink-800">
        <table class="w-full text-sm">
          <thead><tr class="border-b border-ink-800 bg-ink-900/50">
            <th class="px-5 py-3 text-left text-gray-300"></th>
            <th class="px-5 py-3 text-center text-gray-500">This Generator</th>
            <th class="px-5 py-3 text-center text-accent-400">InkFlow Auto</th>
          </tr></thead>
          <tbody class="divide-y divide-ink-800">
            <tr><td class="px-5 py-3 text-gray-400">Generate email template</td><td class="px-5 py-3 text-center text-gray-500">✅</td><td class="px-5 py-3 text-center text-accent-400">✅</td></tr>
            <tr><td class="px-5 py-3 text-gray-400">Auto-send at day 3, 7, 14</td><td class="px-5 py-3 text-center text-gray-500">❌</td><td class="px-5 py-3 text-center text-accent-400">✅</td></tr>
            <tr><td class="px-5 py-3 text-gray-400">SMS + email both channels</td><td class="px-5 py-3 text-center text-gray-500">❌</td><td class="px-5 py-3 text-center text-accent-400">✅</td></tr>
            <tr><td class="px-5 py-3 text-gray-400">Healed photo request auto</td><td class="px-5 py-3 text-center text-gray-500">❌</td><td class="px-5 py-3 text-center text-accent-400">✅</td></tr>
            <tr><td class="px-5 py-3 text-gray-400">100% follow-up consistency</td><td class="px-5 py-3 text-center text-gray-500">Manual</td><td class="px-5 py-3 text-center text-accent-400">✅</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- BUYER GUIDE -->
  <section class="border-t border-ink-800/50 py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white text-center">Which Aftercare Method Is Right for You?</h2>
      <p class="mt-3 text-center text-gray-400">Your choice depends on your client volume and consistency needs.</p>
      <div class="mt-8 space-y-4">
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5"><h3 class="text-white font-semibold text-sm">Solo artist with 5-10 clients/week</h3><p class="mt-1 text-sm text-gray-400">The free generator gives you a reusable template. Paste it into your DMs or email — better than typing each message from scratch.</p></div>
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5"><h3 class="text-white font-semibold text-sm">Multi-artist studio (20+ sessions/week)</h3><p class="mt-1 text-sm text-gray-400">Manual follow-ups don't scale. InkFlow's automation ensures every client gets day 3, 7, and 14 check-ins automatically. No dropped follow-ups.</p></div>
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5"><h3 class="text-white font-semibold text-sm">Studio focused on reviews and portfolio</h3><p class="mt-1 text-sm text-gray-400">Automation captures 40% more healed photos and 2x more reviews than manual follow-up. The generator gives you a single template — automation delivers the full sequence.</p></div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-ink-800/50 py-16 bg-ink-900/20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 space-y-4">
      <h2 class="text-2xl font-bold text-white text-center">Frequently Asked Questions</h2>
      <details class="rounded-xl border border-ink-800 p-4">
        <summary class="cursor-pointer text-sm font-medium text-white">Is the aftercare email generator free?</summary>
        <p class="mt-2 text-sm text-gray-400">Yes. Generate unlimited aftercare email templates for free. No account or signup required.</p>
      </details>
      <details class="rounded-xl border border-ink-800 p-4">
        <summary class="cursor-pointer text-sm font-medium text-white">Can I customize the generated emails?</summary>
        <p class="mt-2 text-sm text-gray-400">Yes. You can edit the generated template before copying. Adjust the tone, add studio-specific details, or modify the instructions.</p>
      </details>
      <details class="rounded-xl border border-ink-800 p-4">
        <summary class="cursor-pointer text-sm font-medium text-white">What's included in the aftercare email?</summary>
        <p class="mt-2 text-sm text-gray-400">Basic aftercare instructions covering washing, moisturizing, sun protection, and healing timeline. The template can be customized for different tattoo types.</p>
      </details>
      <details class="rounded-xl border border-ink-800 p-4">
        <summary class="cursor-pointer text-sm font-medium text-white">How do I send the generated email?</summary>
        <p class="mt-2 text-sm text-gray-400">Copy the generated template and paste into your email client, SMS, or DM. For automated sending, upgrade to InkFlow's aftercare automation.</p>
      </details>
    </div>
  </section>

  <!-- CTA -->
  <!-- Related Studio Software (tool -> product internal links, Phase 1 #3) -->
  <section class="border-t border-ink-800/50 py-16">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white text-center">Run Your Studio on InkFlow</h2>
      <p class="mt-3 text-center text-gray-400">Turn meaning research into booked, managed, and aftercared clients.</p>
      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        <a href="/features/tattoo-aftercare-software-automation" class="group flex items-center gap-4 rounded-xl border border-ink-800 bg-ink-900/30 p-4 hover:border-accent-500/30 transition-all">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-accent-500/15 text-accent-300 text-lg font-bold group-hover:bg-accent-500/25 transition-colors">&#9881;</div>
          <div>
            <p class="font-semibold text-white group-hover:text-accent-300 transition-colors">Aftercare automation suite</p>
            <p class="mt-0.5 text-xs text-gray-500">Day 3 / 7 / 14 sequences &rarr;</p>
          </div>
        </a>
        <a href="/blog/tattoo-aftercare-email-automation" class="group flex items-center gap-4 rounded-xl border border-ink-800 bg-ink-900/30 p-4 hover:border-accent-500/30 transition-all">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-accent-500/15 text-accent-300 text-lg font-bold group-hover:bg-accent-500/25 transition-colors">&#9881;</div>
          <div>
            <p class="font-semibold text-white group-hover:text-accent-300 transition-colors">Email automation guide</p>
            <p class="mt-0.5 text-xs text-gray-500">Read the guide &rarr;</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="border-t border-ink-800/50 py-16 text-center">
    <h2 class="text-2xl font-bold text-white">Stop Writing Aftercare Emails by Hand</h2>
    <p class="mt-3 text-gray-400">InkFlow sends automated aftercare sequences at day 3, 7, and 14. Set it once, runs on autopilot. 40% more healed photos, 2x more reviews.</p>
    <a href="/features/tattoo-aftercare-software-automation" class="mt-6 inline-block rounded-lg bg-accent-500 px-8 py-3.5 text-base font-semibold text-ink-950 hover:bg-accent-400 transition-all">Learn More →</a>
    <p class="mt-3 text-sm text-gray-600"><a href="https://app.ink-flows.com/register" class="text-accent-400 hover:underline">Try InkFlow Free →</a></p>
  </section>
  <Footer />
</BaseLayout>
