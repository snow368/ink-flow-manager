---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { ALL_MEANINGS, getMeaningBySlug, TATTOO_CATEGORIES } from '../../data/tattoo-meanings';

export async function getStaticPaths() {
  return ALL_MEANINGS.map(m => ({
    params: { symbol: m.slug },
    props: { meaning: m },
  }));
}

const { meaning } = Astro.props;
const related = ALL_MEANINGS
  .filter(m => m.slug !== meaning.slug && m.category === meaning.category)
  .slice(0, 4);
const category = TATTOO_CATEGORIES.find(c => c.id === meaning.category);
const pageTitle = `${meaning.name} Tattoo Meaning & Symbolism — InkFlow`;
const pageDesc = `${meaning.name} tattoo meaning: ${meaning.meaning}. Learn about the history, cultural significance, and popular styles for ${meaning.name.toLowerCase()} tattoos.`;
---

<BaseLayout lastUpdated="2026-07-07" author="InkFlow Team">
  <SEOHead slot="head" title={pageTitle} description={pageDesc} />
  <Navbar />

  <!-- Hero -->
  <section class="pt-28 pb-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <p class="text-sm font-semibold text-accent-400 mb-2">
        <a href="/meaning" class="hover:underline">TATTOO MEANINGS</a>
        {category ? <> / <a href={`/meaning/${category.id}`} class="hover:underline">{category.name.toUpperCase()}</a></> : ''}
      </p>
      <div class="grid gap-8 md:grid-cols-2 md:items-start">
        <div>
          <h1 class="text-4xl font-extrabold text-white sm:text-5xl">{meaning.name} Tattoo Meaning</h1>
          <p class="mt-3 text-lg text-accent-400 leading-relaxed">{meaning.meaning}</p>
          {meaning.origin && (
            <p class="mt-2 text-sm text-gray-500">Origin: {meaning.origin}</p>
          )}
          <p class="mt-4 text-gray-400 leading-relaxed">{meaning.desc}</p>
        </div>
        <div class="flex justify-center md:justify-end">
          <div class="flex h-48 w-48 items-center justify-center rounded-2xl border border-ink-700 bg-ink-900/50 text-6xl text-accent-400/40 select-none">
            {meaning.slug === 'wolf' && '🐺'}
            {meaning.slug === 'lion' && '🦁'}
            {meaning.slug === 'snake' && '🐍'}
            {meaning.slug === 'eagle' && '🦅'}
            {meaning.slug === 'butterfly' && '🦋'}
            {meaning.slug === 'owl' && '🦉'}
            {meaning.slug === 'rose' && '🌹'}
            {meaning.slug === 'lotus' && '🪷'}
            {meaning.slug === 'cherry-blossom' && '🌸'}
            {meaning.slug === 'sunflower' && '🌻'}
            {meaning.slug === 'peony' && '🌺'}
            {meaning.slug === 'phoenix' && '🔥'}
            {meaning.slug === 'dragon' && '🐉'}
            {meaning.slug === 'koi-fish' && '🐟'}
            {meaning.slug === 'griffin' && '🦅'}
            {meaning.slug === 'mermaid' && '🧜'}
            {meaning.slug === 'mandala' && '🕉️'}
            {meaning.slug === 'compass' && '🧭'}
            {meaning.slug === 'moon' && '🌙'}
            {meaning.slug === 'arrow' && '🏹'}
            {meaning.slug === 'star' && '⭐'}
            {meaning.slug === 'cross' && '✝️'}
            {meaning.slug === 'eye-of-horus' && '👁️'}
            {meaning.slug === 'hamsa' && '🤚'}
            {meaning.slug === 'om' && '🕉️'}
            {meaning.slug === 'tribal' && '🌀'}
            {meaning.slug === 'celtic-knot' && '🔗'}
            {meaning.slug === 'dreamcatcher' && '🪶'}
            {meaning.slug === 'egyptian' && '🔺'}
            {meaning.slug === 'tree-of-life' && '🌳'}
            {meaning.slug === 'wave' && '🌊'}
            {meaning.slug === 'mountain' && '⛰️'}
            {meaning.slug === 'feather' && '🪶'}
            {meaning.slug === 'anchor' && '⚓'}
            {meaning.slug === 'skull' && '💀'}
            {meaning.slug === 'heart' && '❤️'}
            {meaning.slug === 'key' && '🔑'}
            {meaning.slug === 'geometric' && '◇'}
            {meaning.slug === 'watercolor' && '🎨'}
            {meaning.slug === 'minimalist' && '○'}
            {meaning.slug === 'abstract' && '✦'}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cultural Notes -->
  {meaning.culturalNotes && (
    <section class="border-t border-ink-800/50 py-12">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-white">Cultural Significance</h2>
        <p class="mt-4 text-gray-400 leading-relaxed">{meaning.culturalNotes}</p>
      </div>
    </section>
  )}

  <!-- Custom Sections -->
  {meaning.customSections?.map(section => (
    <section class="border-t border-ink-800/50 py-10">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-xl font-bold text-white">{section.heading}</h2>
        <p class="mt-3 text-gray-400 leading-relaxed">{section.text}</p>
      </div>
    </section>
  ))}

  <!-- Variants -->
  {meaning.variants && meaning.variants.length > 0 && (
    <section class="border-t border-ink-800/50 py-12 bg-ink-900/20">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-white">Popular {meaning.name} Tattoo Variations</h2>
        <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-3">
          {meaning.variants.map(v => (
            <div class="rounded-lg border border-ink-800 bg-ink-900/30 p-3 text-center">
              <p class="text-sm text-gray-300">{v}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Source -->
  {meaning.externalSource && (
    <section class="border-t border-ink-800/50 py-8">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <p class="text-xs text-gray-600">
          Source: <a href={meaning.externalSource} target="_blank" rel="noopener noreferrer" class="text-accent-400 hover:underline">{meaning.sourceLabel || meaning.externalSource}</a>
        </p>
      </div>
    </section>
  )}

  <!-- Related Meanings -->
  {related.length > 0 && (
    <section class="border-t border-ink-800/50 py-12">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-white">More {category?.name || 'Related'} Meanings</h2>
        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          {related.map(r => (
            <a href={`/meaning/${r.slug}`} class="group flex items-center gap-4 rounded-xl border border-ink-800 bg-ink-900/30 p-4 hover:border-accent-500/30 transition-all">
              <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-lg bg-ink-800/50 text-center text-2xl text-gray-400 group-hover:text-accent-400 transition-colors">
                {r.name[0]}
              </div>
              <div>
                <p class="font-semibold text-white group-hover:text-accent-300 transition-colors">{r.name}</p>
                <p class="mt-0.5 text-xs text-gray-500">{r.meaning}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="border-t border-ink-800/50 py-16 text-center">
    <h2 class="text-2xl font-bold text-white">Find Your Perfect Tattoo Design</h2>
    <p class="mt-3 text-gray-400 max-w-xl mx-auto">Get matched with the right meaning and style for your next tattoo.</p>
    <a href="https://app.ink-flows.com/register" class="mt-6 inline-block rounded-lg bg-accent-500 px-8 py-3.5 text-base font-semibold text-ink-950 hover:bg-accent-400 transition-all">Start Your Studio Free →</a>
  </section>

  <section class="border-t border-ink-800/50 py-8">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <p class="text-xs text-gray-600">EEAT: This article was written on 2026-07-07 by InkFlow Team. Cultural and historical information is sourced from academic references and is provided for educational purposes. Meanings may vary across traditions and interpretations.</p>
    </div>
  </section>

  <Footer />
</BaseLayout>
