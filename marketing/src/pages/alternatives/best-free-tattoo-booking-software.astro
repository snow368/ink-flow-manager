          <th class="p-3 text-left font-semibold text-white">Feature</th><th class="p-3 text-center font-semibold text-accent-400">InkFlow</th><th class="p-3 text-center font-semibold text-gray-400">Square Appt</th><th class="p-3 text-center font-semibold text-gray-400">Acuity</th><th class="p-3 text-center font-semibold text-gray-400">Booksy</th>
        </tr></thead><tbody class="divide-y divide-ink-800/50">
          <tr class="hover:bg-ink-900/30"><td class="p-3 text-gray-300">Free Plan</td><td class="p-3 text-center text-accent-300">Forever free</td><td class="p-3 text-center text-gray-500">Limited</td><td class="p-3 text-center text-gray-500">14-day trial</td><td class="p-3 text-center text-gray-500">30-day trial</td></tr>
          <tr class="hover:bg-ink-900/30"><td class="p-3 text-gray-300">Digital Waivers</td><td class="p-3 text-center text-accent-300">Included</td><td class="p-3 text-center text-gray-500">Not available</td><td class="p-3 text-center text-gray-500">Not available</td><td class="p-3 text-center text-gray-500">Not available</td></tr>
