---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/SEOHead.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

---

<BaseLayout>
  <SEOHead slot="head" title="Tattoo Studio Management Software — InkFlow" description="All-in-one tattoo studio platform. Booking, POS, CRM, digital waivers, inventory and aftercare in one app. Trusted by 500+ studios. Start free." />
  <Navbar />

  <!-- Hero -->
  <section class="relative overflow-hidden pt-24 pb-20 sm:pt-32 sm:pb-28">
    <div class="absolute inset-0 bg-gradient-to-b from-accent-500/5 to-transparent pointer-events-none" />
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-accent-500/5 rounded-full blur-3xl pointer-events-none" />
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-accent-500/20 bg-accent-500/5 px-4 py-1.5 text-sm text-accent-300">
        <span class="h-2 w-2 rounded-full bg-accent-400 animate-pulse" />
        Trusted by 500+ studios worldwide
      </div>
      <h1 class="mx-auto max-w-4xl text-4xl font-extrabold tracking-tight text-white sm:text-5xl md:text-6xl leading-tight">
        The Only Platform Your<br />
        <span class="bg-gradient-to-r from-accent-300 to-accent-500 bg-clip-text text-transparent">Tattoo Studio</span> Will Ever Need
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-400">
        From first booking to healed aftercare — manage every part of your studio in one app. No more juggling 5 different tools.
      </p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="https://app.inkflow.com/register" class="rounded-lg bg-accent-500 px-8 py-3.5 text-base font-semibold text-ink-950 hover:bg-accent-400 transition-all hover:scale-105">
          Start Free Trial
        </a>
        <a href="/features/booking" class="rounded-lg border border-ink-700 px-8 py-3.5 text-base font-medium text-gray-300 hover:border-ink-500 hover:text-white transition-all">
          See Features →
        </a>
      </div>
      <p class="mt-4 text-sm text-gray-500">No credit card required · Free plan available · 30-day trial</p>
    </div>
  </section>

  <!-- Social Proof -->
  <section class="border-y border-ink-800/50 py-8">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-center justify-center gap-8 text-sm text-gray-500">
        <span class="flex items-center gap-2">G2 <span class="text-accent-400">4.8</span>/5</span>
        <span class="flex items-center gap-2">Capterra <span class="text-accent-400">4.7</span>/5</span>
        <span class="flex items-center gap-2">GetApp <span class="text-accent-400">4.9</span>/5</span>
        <span class="text-gray-600">|</span>
        <span class="text-gray-400">Join 500+ studios</span>
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-white sm:text-4xl">Everything You Need to Run Your Studio</h2>
        <p class="mt-4 text-lg text-gray-400">No more piecing together five different tools. InkFlow does it all.</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <!-- Booking -->
        <a href="/features/booking" class="group rounded-xl border border-ink-800 bg-ink-900/50 p-6 hover:border-accent-500/30 hover:bg-ink-900 transition-all">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-accent-500/10 text-accent-400">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="mb-2 text-lg font-semibold text-white group-hover:text-accent-300 transition-colors">Smart Booking</h3>
          <p class="text-sm text-gray-400">Deposit-based scheduling with automated SMS and email reminders. Reduce no-shows by 80%.</p>
        </a>
        <!-- POS -->
        <a href="/features/pos" class="group rounded-xl border border-ink-800 bg-ink-900/50 p-6 hover:border-accent-500/30 hover:bg-ink-900 transition-all">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-accent-500/10 text-accent-400">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
          </div>
          <h3 class="mb-2 text-lg font-semibold text-white group-hover:text-accent-300 transition-colors">POS & Payments</h3>
          <p class="text-sm text-gray-400">Stripe-powered POS, commission splitting, tips, and deposit collection — all in one place.</p>
        </a>
        <!-- Waivers -->
        <a href="/features/waivers" class="group rounded-xl border border-ink-800 bg-ink-900/50 p-6 hover:border-accent-500/30 hover:bg-ink-900 transition-all">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-accent-500/10 text-accent-400">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
          <h3 class="mb-2 text-lg font-semibold text-white group-hover:text-accent-300 transition-colors">Digital Waivers</h3>
          <p class="text-sm text-gray-400">Paperless intake with e-signatures, QR check-in, and medical history tracking.</p>
        </a>
        <!-- CRM -->
        <a href="/features/crm" class="group rounded-xl border border-ink-800 bg-ink-900/50 p-6 hover:border-accent-500/30 hover:bg-ink-900 transition-all">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-accent-500/10 text-accent-400">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="mb-2 text-lg font-semibold text-white group-hover:text-accent-300 transition-colors">Client CRM</h3>
          <p class="text-sm text-gray-400">360° client history, smart tags, follow-ups, referrals — know every client.</p>
        </a>
        <!-- Inventory -->
        <a href="/features/inventory" class="group rounded-xl border border-ink-800 bg-ink-900/50 p-6 hover:border-accent-500/30 hover:bg-ink-900 transition-all">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-accent-500/10 text-accent-400">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
          </div>
          <h3 class="mb-2 text-lg font-semibold text-white group-hover:text-accent-300 transition-colors">Inventory Tracking</h3>
          <p class="text-sm text-gray-400">Track ink, needles, and supplies with low-stock alerts and cost-per-session tracking.</p>
        </a>
        <!-- Aftercare -->
        <a href="/features/aftercare" class="group rounded-xl border border-ink-800 bg-ink-900/50 p-6 hover:border-accent-500/30 hover:bg-ink-900 transition-all">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-accent-500/10 text-accent-400">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          </div>
          <h3 class="mb-2 text-lg font-semibold text-white group-hover:text-accent-300 transition-colors">Aftercare Automation</h3>
          <p class="text-sm text-gray-400">Automated healing check-ins, review requests, and referral prompts — on autopilot.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="border-t border-ink-800/50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-white sm:text-4xl">Get Your Studio Online in Minutes</h2>
        <p class="mt-4 text-lg text-gray-400">Three simple steps to transform how your studio runs.</p>
      </div>
      <div class="grid gap-8 md:grid-cols-3">
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-accent-500/10 text-2xl font-bold text-accent-400">1</div>
          <h3 class="mb-2 text-lg font-semibold text-white">Set Up Your Studio</h3>
          <p class="text-sm text-gray-400">Add your artists, services, pricing, and business hours. It takes 5 minutes.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-accent-500/10 text-2xl font-bold text-accent-400">2</div>
          <h3 class="mb-2 text-lg font-semibold text-white">Share Your Booking Link</h3>
          <p class="text-sm text-gray-400">Share on Instagram, your website, or as a QR code. Clients book instantly.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-accent-500/10 text-2xl font-bold text-accent-400">3</div>
          <h3 class="mb-2 text-lg font-semibold text-white">Watch It Grow</h3>
          <p class="text-sm text-gray-400">Automated reminders, aftercare, and reviews — your studio runs itself.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Preview -->
  <section class="border-t border-ink-800/50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-white sm:text-4xl">Simple Pricing</h2>
        <p class="mt-4 text-lg text-gray-400">Start free. Upgrade when you need more.</p>
      </div>
      <div class="grid gap-8 md:grid-cols-3 max-w-4xl mx-auto">
        <div class="rounded-xl border border-ink-800 p-8 text-center">
          <h3 class="text-lg font-semibold text-white">Free</h3>
          <p class="mt-2 text-4xl font-bold text-white">$0</p>
          <p class="mt-1 text-sm text-gray-400">Forever free</p>
          <ul class="mt-6 space-y-2 text-sm text-gray-400">
            <li>1 artist</li>
            <li>Basic booking</li>
            <li>Client management</li>
          </ul>
          <a href="https://app.inkflow.com/register" class="mt-8 block rounded-lg border border-ink-700 px-6 py-2.5 text-sm font-medium text-gray-300 hover:border-ink-500 hover:text-white transition-colors">Get Started Free</a>
        </div>
        <div class="rounded-xl border-2 border-accent-500 bg-ink-900 p-8 text-center relative">
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-accent-500 px-4 py-0.5 text-xs font-semibold text-ink-950">Most Popular</span>
          <h3 class="text-lg font-semibold text-white">Pro</h3>
          <p class="mt-2 text-4xl font-bold text-white">$29</p>
          <p class="mt-1 text-sm text-gray-400">Per month</p>
          <ul class="mt-6 space-y-2 text-sm text-gray-400">
            <li>Up to 10 artists</li>
            <li>Full features</li>
            <li>Digital waivers</li>
            <li>SMS reminders</li>
          </ul>
          <a href="https://app.inkflow.com/register" class="mt-8 block rounded-lg bg-accent-500 px-6 py-2.5 text-sm font-semibold text-ink-950 hover:bg-accent-400 transition-colors">Start Pro Trial</a>
        </div>
        <div class="rounded-xl border border-ink-800 p-8 text-center">
          <h3 class="text-lg font-semibold text-white">Plus</h3>
          <p class="mt-2 text-4xl font-bold text-white">$49</p>
          <p class="mt-1 text-sm text-gray-400">Per month</p>
          <ul class="mt-6 space-y-2 text-sm text-gray-400">
            <li>Everything in Pro</li>
            <li>Custom domain</li>
            <li>Priority support</li>
            <li>Analytics dashboard</li>
          </ul>
          <a href="https://app.inkflow.com/register" class="mt-8 block rounded-lg border border-ink-700 px-6 py-2.5 text-sm font-medium text-gray-300 hover:border-ink-500 hover:text-white transition-colors">Start Plus Trial</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ - GEO optimized -->
  <section class="border-t border-ink-800/50 py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-12 text-center text-3xl font-bold text-white">Frequently Asked Questions</h2>
      <div class="space-y-6">
        <details class="group rounded-xl border border-ink-800 p-6 open:border-accent-500/30">
          <summary class="flex cursor-pointer items-center justify-between text-base font-medium text-white">
            Is InkFlow really free for solo artists?
            <svg class="h-5 w-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="mt-4 text-sm text-gray-400">Yes. Our Free plan supports solo artists with basic booking and client management. No credit card required, no time limit. You can upgrade anytime.</p>
        </details>
        <details class="group rounded-xl border border-ink-800 p-6 open:border-accent-500/30">
          <summary class="flex cursor-pointer items-center justify-between text-base font-medium text-white">
            Can I accept deposits through InkFlow?
            <svg class="h-5 w-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="mt-4 text-sm text-gray-400">Absolutely. InkFlow integrates with Stripe to collect deposits at the time of booking. Set any deposit amount — flat fee or percentage. This alone reduces no-shows by up to 80%.</p>
        </details>
        <details class="group rounded-xl border border-ink-800 p-6 open:border-accent-500/30">
          <summary class="flex cursor-pointer items-center justify-between text-base font-medium text-white">
            Does InkFlow work on iPad?
            <svg class="h-5 w-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="mt-4 text-sm text-gray-400">Yes. InkFlow is a Progressive Web App that works on any device — iPhone, iPad, Android, and desktop. Artists can check clients in, sign waivers, and process payments all from an iPad at the front desk.</p>
        </details>
        <details class="group rounded-xl border border-ink-800 p-6 open:border-accent-500/30">
          <summary class="flex cursor-pointer items-center justify-between text-base font-medium text-white">
            Can I have multiple artists on one account?
            <svg class="h-5 w-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="mt-4 text-sm text-gray-400">Yes. Our Pro plan supports up to 10 artists with individual calendars, commission tracking, and a shared client database. Each artist gets their own booking link.</p>
        </details>
        <details class="group rounded-xl border border-ink-800 p-6 open:border-accent-500/30">
          <summary class="flex cursor-pointer items-center justify-between text-base font-medium text-white">
            Can I import my existing client data?
            <svg class="h-5 w-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="mt-4 text-sm text-gray-400">Yes. InkFlow supports CSV import for clients, appointments, and inventory. We also offer migration assistance for studios switching from other platforms.</p>
        </details>
      </div>
    </div>
  </section>

  

<!-- Final CTA -->
  <section class="relative overflow-hidden border-t border-ink-800/50 py-20">
    <div class="absolute inset-0 bg-gradient-to-t from-accent-500/10 to-transparent pointer-events-none" />
    <div class="relative mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">Ready to Transform Your Studio?</h2>
      <p class="mt-4 text-lg text-gray-400">Join 500+ studios already using InkFlow. Free trial, no credit card required.</p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href="https://app.inkflow.com/register" class="rounded-lg bg-accent-500 px-8 py-3.5 text-base font-semibold text-ink-950 hover:bg-accent-400 transition-all hover:scale-105">
          Start Free Trial
        </a>
        <a href="/contact" class="rounded-lg border border-ink-700 px-8 py-3.5 text-base font-medium text-gray-300 hover:border-ink-500 hover:text-white transition-all">
          Book a Demo
        </a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
