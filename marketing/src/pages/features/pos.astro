---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout>
  <SEOHead slot="head" title="Tattoo POS System — Payments & Commission Split | InkFlow" description="Stripe-powered POS system for tattoo studios. Commission splitting, deposit collection, tips. Accept credit cards, Apple Pay, Google Pay." />
  <Navbar />

  <section class="pt-24 pb-16 sm:pt-32">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Tattoo Shop POS System</h1>
      <p class="mt-6 text-lg text-gray-400">Accept payments, split commissions, collect deposits, and track tips — all integrated with your booking system.</p>
    </div>
  </section>

  <section class="border-t border-ink-800/50 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 space-y-8">
      <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-6">
        <h3 class="text-lg font-semibold text-white">Commission Split</h3>
        <p class="mt-2 text-sm text-gray-400">Set different commission rates per artist. InkFlow automatically calculates payouts after each appointment. No more spreadsheet math.</p>
      </div>
      <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-6">
        <h3 class="text-lg font-semibold text-white">Deposit Collection</h3>
        <p class="mt-2 text-sm text-gray-400">Collect deposits at the time of booking through Stripe. Deposits are tracked as liabilities until the service is completed.</p>
      </div>
    </div>
  </section>

  <section class="py-16 text-center border-t border-ink-800/50">
    <h2 class="text-2xl font-bold text-white">Try InkFlow Free</h2>
    <a href="https://app.inkflow.com/register" class="mt-6 inline-block rounded-lg bg-accent-500 px-8 py-3.5 text-base font-semibold text-ink-950 hover:bg-accent-400 transition-all">Start Free Trial</a>
  </section>
  <Footer />
</BaseLayout>
