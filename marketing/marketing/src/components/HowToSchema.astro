---
interface Step {
  name: string;
  text: string;
  image?: string;
  duration?: string;
}

interface Props {
  /** 指南名称 */
  name: string;
  /** 指南描述 */
  description?: string;
  /** 步骤列表 */
  steps: Step[];
  /** 总耗时 */
  totalTime?: string;
}

const { name, description, steps, totalTime } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name,
  description: description || "",
  step: steps.map((s, i) => ({
    "@type": "HowToStep",
    position: i + 1,
    name: s.name,
    text: s.text,
    ...(s.image ? { image: s.image } : {}),
    ...(s.duration ? { duration: s.duration } : {}),
  })),
  ...(totalTime ? { totalTime } : {}),
};
---

<HowToSection class="my-8">
  <h2 class="text-xl font-bold text-white mb-2">{name}</h2>
  {description && <p class="text-gray-400 text-sm mb-6">{description}</p>}
  <ol class="space-y-6">
    {steps.map((step, i) => (
      <li class="flex gap-4">
        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-accent-500/20 text-accent-400 font-bold text-sm">
          {i + 1}
        </span>
        <div>
          <h3 class="font-semibold text-white">{step.name}</h3>
          <p class="mt-1 text-sm text-gray-400">{step.text}</p>
          {step.duration && (
            <p class="mt-1 text-xs text-gray-500">⏱ {step.duration}</p>
          )}
        </div>
      </li>
    ))}
  </ol>
</HowToSection>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
