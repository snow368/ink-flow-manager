---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import FAQSchema from '../../components/FAQSchema.astro';
import { ALL_MEANINGS, getMeaningBySlug, TATTOO_CATEGORIES } from '../../data/tattoo-meanings';
import { CUSTOM_SECTIONS } from '../../data/tattoo-meanings-custom-sections';
import { EEAT_AUTHOR, EEAT_PUBLISHED, CATEGORY_EEAT } from '../../data/tattoo-category-content';

export async function getStaticPaths() {
  return ALL_MEANINGS.map(m => ({
    params: { symbol: m.slug },
    props: { meaning: m },
  }));
}

const { meaning } = Astro.props;
const related = ALL_MEANINGS
  .filter(m => m.slug !== meaning.slug && m.category === meaning.category)
  .slice(0, 4);
const category = TATTOO_CATEGORIES.find(c => c.id === meaning.category);
const eeat = CATEGORY_EEAT[meaning.category] ?? {};
const reviewer = eeat.reviewer;

// Related Tools & Resources: default to the 2 meaning-relevant free tools;
// per-symbol overrides via meaning.relatedTools (site-structure blueprint).
const DEFAULT_RELATED_TOOLS = [
  { label: 'Tattoo Meaning Finder', href: '/free-tools/tattoo-meaning-finder' },
  { label: 'Tattoo Price Calculator', href: '/free-tools/tattoo-price-calculator' },
];
const relatedTools = meaning.relatedTools ?? DEFAULT_RELATED_TOOLS;
const pageTitle = `${meaning.name} Tattoo Meaning & Symbolism — InkFlow`;
const pageDesc = `${meaning.name} tattoo meaning: ${meaning.meaning}. Learn about the history, cultural significance, and popular styles for ${meaning.name.toLowerCase()} tattoos.`;

const site = 'https://ink-flows.com';
const canonical = `${site}/meaning/${meaning.slug}`;
// Article schema (one per symbol — fixes the 70-page missing-structured-data gap)
const articleJson = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: pageTitle,
  description: pageDesc,
  url: canonical,
  author: {
    '@type': 'Person',
    name: EEAT_AUTHOR.name,
    jobTitle: EEAT_AUTHOR.title,
    url: EEAT_AUTHOR.url,
  },
  publisher: {
    '@type': 'Organization',
    name: 'InkFlow',
    url: site,
    logo: { '@type': 'ImageObject', url: `${site}/images/hero-screenshot-2.png` },
  },
  datePublished: EEAT_PUBLISHED,
  dateModified: EEAT_PUBLISHED,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  image: {
    '@type': 'ImageObject',
    url: `${site}/images/hero-screenshot-2.png`,
    caption: `${meaning.name} tattoo meaning — visual guide`,
    width: 1200,
    height: 630,
  },
  about: { '@type': 'Thing', name: `${meaning.name} tattoo meaning` },
});
// Breadcrumb trail: Home > Meanings > Category > Symbol
const breadcrumbJson = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${site}/` },
    { '@type': 'ListItem', position: 2, name: 'Tattoo Meanings', item: `${site}/meaning` },
    ...(category
      ? [{
          '@type': 'ListItem',
          position: 3,
          name: category.name,
          item: `${site}/meaning/category/${category.id}`,
        }, {
          '@type': 'ListItem',
          position: 4,
          name: meaning.name,
          item: canonical,
        }]
      : [{ '@type': 'ListItem', position: 3, name: meaning.name, item: canonical }]),
  ],
});

// FAQPage schema derived from REAL symbol fields (no fabricated content).
// 3 Q&A when culturalNotes exists, 2 otherwise — every answer reuses source data.
const symbolFaqs = [
  {
    question: `What does a ${meaning.name} tattoo symbolize?`,
    answer: `${meaning.name} tattoos symbolize ${meaning.meaning.toLowerCase()}. ${meaning.desc}`,
  },
  ...(meaning.origin
    ? [{
        question: `Where did ${meaning.name} tattoos originate?`,
        answer: `${meaning.name} tattoo imagery traces back to ${meaning.origin}. ${meaning.desc}`,
      }]
    : []),
  ...(meaning.culturalNotes
    ? [{
        question: `What is the cultural significance of ${meaning.name} tattoos?`,
        answer: meaning.culturalNotes,
      }]
    : []),
];
---

<BaseLayout lastUpdated="2026-07-07" author="Sarah Chen">
  <SEOHead slot="head" title={pageTitle} description={pageDesc} appSchema={false} disableBreadcrumb />
  <Navbar />

  <script type="application/ld+json" set:html={articleJson} />
  <script type="application/ld+json" set:html={breadcrumbJson} />
  <FAQSchema questions={symbolFaqs} />

  <!-- Hero -->
  <section class="pt-28 pb-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <p class="text-sm font-semibold text-accent-400 mb-2">
        <a href="/meaning" class="hover:underline">TATTOO MEANINGS</a>
        {category ? <> / <a href={`/meaning/category/${category.id}`} class="hover:underline">{category.name.toUpperCase()}</a></> : ''}
      </p>
      <div class="grid gap-8 md:grid-cols-2 md:items-start">
        <div>
          <h1 class="text-4xl font-extrabold text-white sm:text-5xl">{meaning.name} Tattoo Meaning</h1>
          <p class="mt-3 text-lg text-accent-400 leading-relaxed">{meaning.meaning}</p>
          {meaning.origin && (
            <p class="mt-2 text-sm text-gray-500">Origin: {meaning.origin}</p>
          )}
          <p class="mt-4 text-gray-400 leading-relaxed">{meaning.desc}</p>
        </div>
        <div class="flex justify-center md:justify-end">
          <div class="flex h-48 w-48 items-center justify-center rounded-2xl border border-ink-700 bg-ink-900/50 text-6xl text-accent-400/40 select-none">
            {meaning.slug === 'wolf' && '🐺'}
            {meaning.slug === 'lion' && '🦁'}
            {meaning.slug === 'snake' && '🐍'}
            {meaning.slug === 'eagle' && '🦅'}
            {meaning.slug === 'butterfly' && '🦋'}
            {meaning.slug === 'owl' && '🦉'}
            {meaning.slug === 'rose' && '🌹'}
            {meaning.slug === 'lotus' && '🪷'}
            {meaning.slug === 'cherry-blossom' && '🌸'}
            {meaning.slug === 'sunflower' && '🌻'}
            {meaning.slug === 'peony' && '🌺'}
            {meaning.slug === 'phoenix' && '🔥'}
            {meaning.slug === 'dragon' && '🐉'}
            {meaning.slug === 'koi-fish' && '🐟'}
            {meaning.slug === 'griffin' && '🦅'}
            {meaning.slug === 'mermaid' && '🧜'}
            {meaning.slug === 'mandala' && '🕉️'}
            {meaning.slug === 'compass' && '🧭'}
            {meaning.slug === 'moon' && '🌙'}
            {meaning.slug === 'arrow' && '🏹'}
            {meaning.slug === 'star' && '⭐'}
            {meaning.slug === 'cross' && '✝️'}
            {meaning.slug === 'eye-of-horus' && '👁️'}
            {meaning.slug === 'hamsa' && '🤚'}
            {meaning.slug === 'om' && '🕉️'}
            {meaning.slug === 'tribal' && '🌀'}
            {meaning.slug === 'celtic-knot' && '🔗'}
            {meaning.slug === 'dreamcatcher' && '🪶'}
            {meaning.slug === 'egyptian' && '🔺'}
            {meaning.slug === 'tree-of-life' && '🌳'}
            {meaning.slug === 'wave' && '🌊'}
            {meaning.slug === 'mountain' && '⛰️'}
            {meaning.slug === 'feather' && '🪶'}
            {meaning.slug === 'anchor' && '⚓'}
            {meaning.slug === 'skull' && '💀'}
            {meaning.slug === 'heart' && '❤️'}
            {meaning.slug === 'key' && '🔑'}
            {meaning.slug === 'geometric' && '◇'}
            {meaning.slug === 'watercolor' && '🎨'}
            {meaning.slug === 'minimalist' && '○'}
            {meaning.slug === 'abstract' && '✦'}
            {!['wolf','lion','snake','eagle','butterfly','owl','rose','lotus','cherry-blossom','sunflower','peony','phoenix','dragon','koi-fish','griffin','mermaid','mandala','compass','moon','arrow','star','cross','eye-of-horus','hamsa','om','tribal','celtic-knot','dreamcatcher','egyptian','tree-of-life','wave','mountain','feather','anchor','skull','heart','key','geometric','watercolor','minimalist','abstract'].includes(meaning.slug) && meaning.name[0]}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cultural Notes -->
  {meaning.culturalNotes && (
    <section class="border-t border-ink-800/50 py-12">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-white">Cultural Significance</h2>
        <p class="mt-4 text-gray-400 leading-relaxed">{meaning.culturalNotes}</p>
      </div>
    </section>
  )}

  <!-- Custom Sections (inline + external) -->
  {(meaning.customSections || CUSTOM_SECTIONS[meaning.slug] || []).map(section => (
    <section class="border-t border-ink-800/50 py-10">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-xl font-bold text-white">{section.heading}</h2>
        <p class="mt-3 text-gray-400 leading-relaxed">{section.text}</p>
      </div>
    </section>
  ))}

  <!-- Variants -->
  {meaning.variants && meaning.variants.length > 0 && (
    <section class="border-t border-ink-800/50 py-12 bg-ink-900/20">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-white">Popular {meaning.name} Tattoo Variations</h2>
        <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-3">
          {meaning.variants.map(v => (
            <div class="rounded-lg border border-ink-800 bg-ink-900/30 p-3 text-center">
              <p class="text-sm text-gray-300">{v}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Source -->
  {meaning.externalSource && (
    <section class="border-t border-ink-800/50 py-8">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <p class="text-xs text-gray-600">
          Source: <a href={meaning.externalSource} target="_blank" rel="noopener noreferrer" class="text-accent-400 hover:underline">{meaning.sourceLabel || meaning.externalSource}</a>
        </p>
      </div>
    </section>
  )}

  <!-- Related Meanings -->
  {related.length > 0 && (
    <section class="border-t border-ink-800/50 py-12">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-white">More {category?.name || 'Related'} Meanings</h2>
        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          {related.map(r => (
            <a href={`/meaning/${r.slug}`} class="group flex items-center gap-4 rounded-xl border border-ink-800 bg-ink-900/30 p-4 hover:border-accent-500/30 transition-all">
              <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-lg bg-ink-800/50 text-center text-2xl text-gray-400 group-hover:text-accent-400 transition-colors">
                {r.name[0]}
              </div>
              <div>
                <p class="font-semibold text-white group-hover:text-accent-300 transition-colors">{r.name}</p>
                <p class="mt-0.5 text-xs text-gray-500">{r.meaning}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Related Tools & Resources (informational -> commercial internal links) -->
  {relatedTools.length > 0 && (
    <section class="border-t border-ink-800/50 py-12 bg-ink-900/20">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-white">Related Tools &amp; Resources</h2>
        <p class="mt-2 text-sm text-gray-500">Find, price, and book the design you're exploring.</p>
        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          {relatedTools.map((t) => (
            <a href={t.href} class="group flex items-center gap-4 rounded-xl border border-ink-800 bg-ink-900/30 p-4 hover:border-accent-500/30 transition-all">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-accent-500/15 text-accent-300 text-lg font-bold group-hover:bg-accent-500/25 transition-colors">&#9881;</div>
              <div>
                <p class="font-semibold text-white group-hover:text-accent-300 transition-colors">{t.label}</p>
                <p class="mt-0.5 text-xs text-gray-500">Open tool &rarr;</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- FAQ (mirrors FAQPage JSON-LD so schema corresponds to visible content) -->
  {symbolFaqs.length > 0 && (
    <section class="border-t border-ink-800/50 py-12">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-white">Frequently Asked Questions</h2>
        <div class="mt-6 space-y-4">
          {symbolFaqs.map(f => (
            <details class="rounded-xl border border-ink-800 p-4">
              <summary class="cursor-pointer text-sm font-medium text-white">{f.question}</summary>
              <p class="mt-2 text-sm text-gray-400">{f.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="border-t border-ink-800/50 py-16 text-center">
    <h2 class="text-2xl font-bold text-white">Find Your Perfect Tattoo Design</h2>
    <p class="mt-3 text-gray-400 max-w-xl mx-auto">Get matched with the right meaning and style for your next tattoo.</p>
    <a href="https://app.ink-flows.com/register" class="mt-6 inline-block rounded-lg bg-accent-500 px-8 py-3.5 text-base font-semibold text-ink-950 hover:bg-accent-400 transition-all">Start Your Studio Free →</a>
  </section>

  <!-- Cultural Respect (differentiator vs top-10 competitors) -->
  <section class="border-t border-ink-800/50 py-8 bg-ink-900/20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-lg font-bold text-white">A Note on Cultural Respect</h2>
      <p class="mt-2 text-sm text-gray-400">Tattoo meanings are shaped by culture, history, and personal story — they are not universal or fixed. Sacred designs (e.g. Polynesian tatau, Indigenous, or religious iconography) carry deep meaning for the communities who created them; we share this for education and ask that you research and respect their origins before wearing them. This guide is not a substitute for cultural consultation.</p>
      <p class="mt-3 text-sm text-gray-500">See also our <a href="/meaning/style-guide" class="text-accent-400 hover:underline">Color &amp; Style Meaning Guide</a> for how color and technique change a design's meaning.</p>
    </div>
  </section>

  <section class="border-t border-ink-800/50 py-8">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <p class="text-xs text-gray-600">EEAT: Written by {EEAT_AUTHOR.name} ({EEAT_AUTHOR.title}).{reviewer ? ` Reviewed by ${reviewer.name}, ${reviewer.title}.` : ''} Cultural and historical information is sourced from academic references and is provided for educational purposes. Meanings vary across traditions and interpretations.</p>
    </div>
  </section>

  <Footer />
</BaseLayout>
