---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { EEAT_AUTHOR, EEAT_PUBLISHED } from '../../data/tattoo-category-content';
import { COLOR_MEANINGS, STYLE_MEANINGS } from '../../data/tattoo-style-glossary';

const site = 'https://ink-flows.com';
const canonical = `${site}/meaning/style-guide`;
const pageTitle = 'Tattoo Color & Style Meaning Guide — InkFlow';
const pageDesc = 'What tattoo colors and styles symbolize — from red and blackwork to watercolor and fine-line. A cross-cutting reference for choosing a design that means what you intend.';

const articleJson = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: pageTitle,
  description: pageDesc,
  url: canonical,
  author: {
    '@type': 'Person',
    name: EEAT_AUTHOR.name,
    jobTitle: EEAT_AUTHOR.title,
    url: EEAT_AUTHOR.url,
  },
  publisher: {
    '@type': 'Organization',
    name: 'InkFlow',
    url: site,
    logo: { '@type': 'ImageObject', url: `${site}/images/hero-screenshot-2.png` },
  },
  datePublished: EEAT_PUBLISHED,
  dateModified: EEAT_PUBLISHED,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
});
---

<BaseLayout
  breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Tattoo Meanings', href: '/meaning' }, { label: 'Style Guide' }]}
  lastUpdated={EEAT_PUBLISHED}
>
  <SEOHead slot="head" title={pageTitle} description={pageDesc} canonical={canonical} appSchema={false} />
  <script type="application/ld+json" set:html={articleJson} />
  <Navbar />

  <section class="pt-28 pb-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <p class="text-sm font-semibold text-accent-400 mb-2"><a href="/meaning" class="hover:underline">TATTOO MEANINGS</a></p>
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Tattoo Color &amp; Style Meaning Guide</h1>
      <p class="mt-3 text-lg text-gray-400">The same symbol reads differently in red vs black, or in watercolor vs American traditional. This cross-cutting reference helps you choose a design that means what you intend.</p>
    </div>
  </section>

  <!-- Colors -->
  <section class="border-t border-ink-800/50 py-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white">What Tattoo Colors Symbolize</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        {COLOR_MEANINGS.map(c => (
          <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5">
            <h3 class="text-lg font-semibold text-white">{c.name}</h3>
            <p class="mt-1 text-sm text-accent-400">{c.meaning}</p>
            {c.note && <p class="mt-2 text-xs text-gray-500">{c.note}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Styles -->
  <section class="border-t border-ink-800/50 py-12 bg-ink-900/20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white">What Tattoo Styles Symbolize</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        {STYLE_MEANINGS.map(s => (
          <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5">
            <h3 class="text-lg font-semibold text-white">{s.name}</h3>
            <p class="mt-1 text-sm text-accent-400">{s.meaning}</p>
            {s.note && <p class="mt-2 text-xs text-gray-500">{s.note}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Cultural Respect -->
  <section class="border-t border-ink-800/50 py-8 bg-ink-900/20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-lg font-bold text-white">A Note on Cultural Respect</h2>
      <p class="mt-2 text-sm text-gray-400">Color and style meanings are shaped by culture, history, and personal story — they are not universal or fixed. Sacred styles (e.g. Polynesian tatau, Indigenous, or religious iconography) carry deep meaning for the communities who created them; we share this for education and ask that you research and respect their origins before wearing them. This guide is not a substitute for cultural consultation.</p>
    </div>
  </section>

  <section class="border-t border-ink-800/50 py-8">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <p class="text-xs text-gray-600">EEAT: Written by {EEAT_AUTHOR.name} ({EEAT_AUTHOR.title}). Cultural and historical information is sourced from academic references and is provided for educational purposes. Meanings vary across traditions and interpretations.</p>
      <p class="mt-2 text-sm text-gray-500">Browse all symbol meanings in the <a href="/meaning" class="text-accent-400 hover:underline">Tattoo Meanings directory</a>.</p>
    </div>
  </section>

  <Footer />
</BaseLayout>
