---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import FAQSchema from '../../components/FAQSchema.astro';
import { TATTOO_CATEGORIES, ALL_MEANINGS } from '../../data/tattoo-meanings';
---

<BaseLayout lastUpdated="2026-07-07" author="Sarah Chen">
  <SEOHead slot="head" title="Tattoo Meanings Directory — Search Symbolism & Design Meanings | InkFlow" description={`Discover the meaning behind ${ALL_MEANINGS.length} popular tattoo symbols. Animals, flowers, mythological creatures, geometric & celestial designs, religious & spiritual symbols, cultural & tribal traditions, nature, objects, modern styles, birds, zodiac, insects, sea life, time & mortality, and words & lettering. Free reference.`} />
  <FAQSchema questions={[
    { question: "How many tattoo meanings are in this directory?", answer: `${ALL_MEANINGS.length} symbols across ${TATTOO_CATEGORIES.length} categories including animals, flowers, mythological creatures, geometric & celestial designs, religious & spiritual symbols, cultural & tribal traditions, nature, objects, modern styles, birds, zodiac & astrology, insects, sea life, time & mortality, and words & lettering.` },
    { question: "Are meanings based on cultural accuracy?", answer: "Yes. We cite cultural and historical sources for traditional meanings. Modern interpretations are labeled as such. All information is for educational purposes." },
    { question: "Can I suggest a meaning to add?", answer: "Yes. Contact us with your suggestion and source references. We review and add new meanings regularly." },
  ]} />
  <Navbar />

  <section class="pt-28 pb-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold text-accent-400 mb-3">REFERENCE</p>
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Tattoo Meanings Directory</h1>
      <p class="mt-4 text-lg text-gray-400 max-w-2xl mx-auto">Discover the history, symbolism, and cultural significance behind {ALL_MEANINGS.length} popular tattoo symbols. Browse by category or search for a specific design.</p>
    </div>
  </section>

  <!-- Categories -->
  {TATTOO_CATEGORIES.map(cat => (
    <section class="border-t border-ink-800/50 py-12" id={cat.id}>
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="flex items-baseline justify-between mb-6">
          <div>
            <h2 class="text-2xl font-bold text-white">{cat.name}</h2>
            <p class="text-sm text-gray-500 mt-1">{cat.desc}</p>
            <a href={`/meaning/category/${cat.id}`} class="mt-2 inline-block text-xs font-medium text-accent-400 hover:underline">View all {cat.name} meanings →</a>
          </div>
          <span class="text-xs text-gray-600">{cat.symbols.length} symbols</span>
        </div>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {cat.symbols.map(s => (
            <a href={`/meaning/${s.slug}`} class="group rounded-xl border border-ink-800 bg-ink-900/30 p-5 hover:border-accent-500/30 transition-all">
              <div class="flex items-center gap-3">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-ink-800/50 text-lg text-gray-400 group-hover:text-accent-400 transition-colors">
                  {s.name[0]}
                </div>
                <div>
                  <h3 class="font-semibold text-white group-hover:text-accent-300 transition-colors">{s.name}</h3>
                  <p class="text-xs text-gray-500 mt-0.5 line-clamp-1">{s.meaning}</p>
                </div>
              </div>
              <p class="mt-3 text-xs text-gray-500 leading-relaxed line-clamp-2">{s.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="border-t border-ink-800/50 py-16 text-center bg-ink-900/20">
    <h2 class="text-2xl font-bold text-white">Know Your Symbolism</h2>
    <p class="mt-3 text-gray-400 max-w-xl mx-auto">Help your clients choose meaningful designs. InkFlow helps you manage bookings, waivers, and aftercare — all in one place.</p>
    <a href="https://app.ink-flows.com/register" class="mt-6 inline-block rounded-lg bg-accent-500 px-8 py-3.5 text-base font-semibold text-ink-950 hover:bg-accent-400 transition-all">Start Free →</a>
  </section>

  <Footer />
</BaseLayout>
