---
interface Props {
  /** 信息来源，如 "Cleveland Clinic" */
  source?: string;
  /** 来源 URL */
  sourceUrl?: string;
  /** 自定义说明文本 */
  text?: string;
}

const { source, sourceUrl, text } = Astro.props;
---

<div class="medical-disclaimer rounded-xl border border-amber-800/40 bg-amber-950/20 p-4 text-sm">
  <div class="flex gap-3">
    <span class="mt-0.5 flex-shrink-0 text-amber-400 text-lg">⚠️</span>
    <div class="text-gray-400 leading-relaxed">
      {text ? (
        <p>{text}</p>
      ) : (
        <>
          <p class="font-medium text-amber-300">Medical Disclaimer</p>
          <p class="mt-1">
            The information provided is for educational purposes only and does not constitute medical advice.
            Tattoo aftercare practices vary. Always consult a licensed tattoo artist or healthcare provider
            for personalized guidance on healing and aftercare.
          </p>
        </>
      )}
      {source && sourceUrl && (
        <p class="mt-2 text-xs text-gray-500">
          Source: <a href={sourceUrl} target="_blank" rel="noopener noreferrer" class="text-amber-400 hover:underline">{source}</a>
        </p>
      )}
    </div>
  </div>
</div>
