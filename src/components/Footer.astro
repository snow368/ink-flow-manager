---
import { t } from "../i18n/utils";
import { DEFAULT_LOCALE, type Locale } from "../i18n/config";

const locale: Locale = (Astro.currentLocale as Locale) || DEFAULT_LOCALE;
const base = locale === 'es' ? '/es' : '';
---
<footer class="border-t border-ink-800/50 bg-ink-950">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4">
      <div>
        <h3 class="mb-4 text-sm font-semibold text-white">{t(locale, 'footer.features')}</h3>
        <ul class="space-y-2">
          <li><a href={`${base}/features/tattoo-booking-software`} class="text-sm text-gray-400 hover:text-white transition-colors">{t(locale, 'feat.booking')}</a></li>
          <li><a href={`${base}/features/tattoo-payment-processing`} class="text-sm text-gray-400 hover:text-white transition-colors">{t(locale, 'feat.payments')}</a></li>
          <li><a href={`${base}/features/tattoo-waiver-software`} class="text-sm text-gray-400 hover:text-white transition-colors">{t(locale, 'feat.waivers')}</a></li>
          <li><a href={`${base}/features/tattoo-crm-software`} class="text-sm text-gray-400 hover:text-white transition-colors">{t(locale, 'feat.crm')}</a></li>
          <li><a href={`${base}/features/tattoo-aftercare-software-automation`} class="text-sm text-gray-400 hover:text-white transition-colors">{t(locale, 'feat.aftercare')}</a></li>
        </ul>
      </div>
      <div>
        <h3 class="mb-4 text-sm font-semibold text-white">{t(locale, 'footer.compare')}</h3>
        <ul class="space-y-2">
          <li><a href={`${base}/compare/tattoo-studio-pro`} class="text-sm text-gray-400 hover:text-white transition-colors">{t(locale, 'cmp.studioPro')}</a></li>
          <li><a href={`${base}/compare/tattoogenda`} class="text-sm text-gray-400 hover:text-white transition-colors">{t(locale, 'cmp.tattoogenda')}</a></li>
          <li><a href={`${base}/compare/booksy`} class="text-sm text-gray-400 hover:text-white transition-colors">{t(locale, 'cmp.booksy')}</a></li>
          <li><a href={`${base}/compare/vagaro`} class="text-sm text-gray-400 hover:text-white transition-colors">{t(locale, 'cmp.vagaro')}</a></li>
        </ul>
      </div>
      <div>
        <h3 class="mb-4 text-sm font-semibold text-white">{t(locale, 'footer.resources')}</h3>
        <ul class="space-y-2">
          <li><a href={`${base}/blog`} class="text-sm text-gray-400 hover:text-white transition-colors">{t(locale, 'footer.blog')}</a></li>
          <li><a href={`${base}/pricing`} class="text-sm text-gray-400 hover:text-white transition-colors">{t(locale, 'footer.pricing')}</a></li>
          <li><a href={`${base}/download`} class="text-sm text-gray-400 hover:text-white transition-colors">{t(locale, 'footer.download')}</a></li>
        </ul>
      </div>
      <div>
        <h3 class="mb-4 text-sm font-semibold text-white">{t(locale, 'footer.company')}</h3>
        <ul class="space-y-2">
          <li><a href={`${base}/about`} class="text-sm text-gray-400 hover:text-white transition-colors">{t(locale, 'footer.about')}</a></li>
          <li><a href={`${base}/contact`} class="text-sm text-gray-400 hover:text-white transition-colors">{t(locale, 'footer.contact')}</a></li>
          <li><a href={`${base}/privacy`} class="text-sm text-gray-400 hover:text-white transition-colors">{t(locale, 'footer.privacy')}</a></li>
          <li><a href={`${base}/terms`} class="text-sm text-gray-400 hover:text-white transition-colors">{t(locale, 'footer.terms')}</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-12 border-t border-ink-800/50 pt-8 text-center">
      <p class="text-sm text-gray-500">&copy; 2026 InkFlow. All rights reserved.</p>
    </div>
  </div>
</footer>
