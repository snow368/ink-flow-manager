---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/SEOHead.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageSchema from '../components/PageSchema.astro';
import FAQSchema from '../components/FAQSchema.astro';
import { APP_PLANS, WEBSITE_PLANS, type PricingTier } from '../data/pricing';

// Generate Product+Offer schema from data source
const appOffers = APP_PLANS.map(p => ({
  "@type": "Offer" as const,
  "name": p.name,
  "price": p.monthly.toString(),
  "priceCurrency": "USD",
  "description": `${p.features[0]}${p.features.length > 1 ? `, ${p.features.slice(1, 4).join(', ')}` : ''}`,
}));
const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "InkFlow Plans",
  "brand": { "@type": "Brand", "name": "InkFlow" },
  "description": "Free for solo artists. Starter $9.99/mo, Pro $29.99/mo, Plus $49.99/mo.",
  "offers": appOffers,
};
---

<BaseLayout>
  <SEOHead slot="head"
    title="InkFlow Pricing — Free, Starter $9.99, Pro $29.99, Plus $49.99 | Tattoo Studio Software"
    description="Free for solo artists. Starter $9.99/mo, Pro $29.99/mo, Plus $49.99/mo for multi-location. Annual plans available. Start free, upgrade when you grow."
  />
  <PageSchema type="software" data={{
    description: "Tattoo studio management software. Free forever, Starter $9.99/mo, Pro $29.99/mo, Plus $49.99/mo.",
    offers: { price: "0", currency: "USD" },
    aggregateRating: { value: "4.8", count: "127" },
  }} />
  <!-- Product schema (from data source) -->
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <FAQSchema questions={[
    { question: "Is there a free plan?", answer: "Yes. Free forever — basic manual client management and booking. No cloud sync, no online booking. Upgrade to Starter for the full experience." },
    { question: "What is the difference between Free and Starter?", answer: "Free is manual and local-only. Starter adds online booking, digital waivers, CRM with cloud sync, SMS/email reminders, and payment collection." },
    { question: "Can I switch plans later?", answer: "Yes. Upgrade or downgrade anytime. Upgrades take effect immediately, downgrades at the next billing cycle." },
    { question: "What is included in the beta period?", answer: "During beta testing, all features are free on every plan. No payment needed. We will notify you before the official launch." },
    { question: "How does multi-shop pricing work on Plus?", answer: "First shop is $29.99/mo. Each additional shop is $15/mo. All locations managed from one dashboard with cross-shop analytics." },
  ]} />
  <Navbar />

  <!-- HERO -->
  <section class="pt-24 pb-16 sm:pt-32">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold text-accent-400 mb-3">PRICING</p>
      <div class="inline-block rounded-full bg-accent-500/10 border border-accent-500/30 px-4 py-1.5 text-xs text-accent-400 mb-4">🚀 Beta — all features free. Suggest a feature & get 3 months Pro.</div>
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Free for Solo Artists. Upgrade When You Grow.</h1>
      <p class="mt-4 text-lg text-gray-400 max-w-2xl mx-auto">All features are free during beta. Upgrade to Starter, Pro, or Plus when we launch. No credit card needed.</p>
    </div>
  </section>

  <!-- APP PLANS -->
  <section class="pb-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 md:grid-cols-4 max-w-6xl mx-auto">

        {APP_PLANS.map((plan) => (
          <div class={`rounded-xl border ${plan.popular ? 'border-2 border-accent-500 bg-ink-900' : 'border-ink-800 bg-ink-900/30'} p-8 flex flex-col relative`}>
            {plan.popular && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-accent-500 px-4 py-0.5 text-xs font-semibold text-ink-950">Most Popular</span>
            )}
            <h2 class="text-lg font-semibold text-white">{plan.name}</h2>
            <p class="mt-2 text-4xl font-bold text-white">{plan.monthlyLabel}</p>
            <p class="mt-1 text-sm text-gray-400">{plan.subtitle}</p>
            {plan.annualSaving > 0 && (
              <p class="text-xs text-gray-500">or <strong class="text-gray-300">{plan.annualLabel}</strong> <span class="text-accent-400">(save ${plan.annualSaving.toFixed(2)})</span></p>
            )}
            <ul class="mt-8 space-y-3 text-sm text-gray-400 flex-1">
              {plan.features.map((feat) => (
                <li class="flex items-start gap-2">
                  <span class="mt-0.5 text-accent-400 shrink-0">{feat.startsWith('Everything') || feat.startsWith('Enhanced') || feat.startsWith('Unlimited') || feat.startsWith('Multi') ? '+' : '✓'}</span>
                  <span>{feat}</span>
                </li>
              ))}
            </ul>
            <a href="https://app.ink-flows.com/register"
               class={`mt-8 block w-full rounded-lg py-2.5 text-center text-sm font-medium transition-colors ${
                 plan.popular
                   ? 'bg-accent-500 text-ink-950 hover:bg-accent-400 font-semibold'
                   : 'border border-ink-700 text-gray-300 hover:border-ink-500 hover:text-white'
               }`}>
              {plan.id === 'free' ? 'Get Started Free' : `Upgrade to ${plan.name}`}
            </a>
          </div>
        ))}

      </div>
    </div>
  </section>

  <!-- FEATURE COMPARISON TABLE -->
  <section class="border-t border-ink-800/50 py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white mb-8 text-center">Full Feature Comparison</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-gray-400">
          <thead class="text-left text-xs uppercase text-gray-500">
            <tr class="border-b border-ink-800">
              <th class="pb-4 pr-4 font-medium">Feature</th>
              <th class="pb-4 pr-4 font-medium text-center">Free</th>
              <th class="pb-4 pr-4 font-medium text-center">Starter</th>
              <th class="pb-4 pr-4 font-medium text-center text-accent-400">Pro</th>
              <th class="pb-4 font-medium text-center">Plus</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-ink-800/50">
            <tr><td class="py-3 pr-4">Artists</td><td class="py-3 pr-4 text-center">1</td><td class="py-3 pr-4 text-center">1</td><td class="py-3 pr-4 text-center text-accent-400">5</td><td class="py-3 text-center text-accent-400">∞</td></tr>
            <tr><td class="py-3 pr-4">Online booking</td><td class="py-3 pr-4 text-center text-gray-600">✗</td><td class="py-3 pr-4 text-center text-green-400">✓</td><td class="py-3 pr-4 text-center text-green-400">✓</td><td class="py-3 text-center text-green-400">✓</td></tr>
            <tr><td class="py-3 pr-4">Digital waivers</td><td class="py-3 pr-4 text-center text-gray-600">✗</td><td class="py-3 pr-4 text-center text-green-400">✓</td><td class="py-3 pr-4 text-center text-green-400">✓</td><td class="py-3 text-center text-green-400">✓</td></tr>
            <tr><td class="py-3 pr-4">Client CRM + cloud</td><td class="py-3 pr-4 text-center text-gray-600">✗</td><td class="py-3 pr-4 text-center text-green-400">✓</td><td class="py-3 pr-4 text-center text-green-400">✓</td><td class="py-3 text-center text-green-400">✓</td></tr>
            <tr><td class="py-3 pr-4">Deposit & payments</td><td class="py-3 pr-4 text-center text-gray-600">✗</td><td class="py-3 pr-4 text-center text-green-400">✓</td><td class="py-3 pr-4 text-center text-green-400">✓</td><td class="py-3 text-center text-green-400">✓</td></tr>
            <tr><td class="py-3 pr-4">SMS & email reminders</td><td class="py-3 pr-4 text-center text-gray-600">✗</td><td class="py-3 pr-4 text-center text-green-400">✓</td><td class="py-3 pr-4 text-center text-green-400">✓</td><td class="py-3 text-center text-green-400">✓</td></tr>
            <tr><td class="py-3 pr-4">Multi-artist calendar</td><td class="py-3 pr-4 text-center text-gray-600">✗</td><td class="py-3 pr-4 text-center text-gray-600">✗</td><td class="py-3 pr-4 text-center text-green-400">✓</td><td class="py-3 text-center text-green-400">✓</td></tr>
            <tr><td class="py-3 pr-4">Commission splitting</td><td class="py-3 pr-4 text-center text-gray-600">✗</td><td class="py-3 pr-4 text-center text-gray-600">✗</td><td class="py-3 pr-4 text-center text-green-400">✓</td><td class="py-3 text-center text-green-400">✓</td></tr>
            <tr><td class="py-3 pr-4">Aftercare automation</td><td class="py-3 pr-4 text-center text-gray-600">✗</td><td class="py-3 pr-4 text-center text-gray-600">✗</td><td class="py-3 pr-4 text-center text-green-400">✓</td><td class="py-3 text-center text-green-400">✓</td></tr>
            <tr><td class="py-3 pr-4">Inventory tracking</td><td class="py-3 pr-4 text-center text-gray-600">✗</td><td class="py-3 pr-4 text-center text-gray-600">✗</td><td class="py-3 pr-4 text-center text-green-400">✓</td><td class="py-3 text-center text-green-400">✓</td></tr>
            <tr><td class="py-3 pr-4">Photo management</td><td class="py-3 pr-4 text-center text-gray-600">✗</td><td class="py-3 pr-4 text-center text-green-400">✓</td><td class="py-3 pr-4 text-center text-green-400">✓</td><td class="py-3 text-center text-green-400">✓</td></tr>
            <tr><td class="py-3 pr-4">Google review requests</td><td class="py-3 pr-4 text-center text-gray-600">✗</td><td class="py-3 pr-4 text-center text-green-400">✓</td><td class="py-3 pr-4 text-center text-green-400">✓</td><td class="py-3 text-center text-green-400">✓</td></tr>
            <tr><td class="py-3 pr-4">Referral program</td><td class="py-3 pr-4 text-center text-gray-600">✗</td><td class="py-3 pr-4 text-center text-green-400">✓</td><td class="py-3 pr-4 text-center text-green-400">✓</td><td class="py-3 text-center text-green-400">✓</td></tr>
            <tr><td class="py-3 pr-4">Free website page</td><td class="py-3 pr-4 text-center text-gray-600">✗</td><td class="py-3 pr-4 text-center text-green-400">1 page</td><td class="py-3 pr-4 text-center text-green-400">10 pages</td><td class="py-3 text-center text-green-400">Unlimited</td></tr>
            <tr><td class="py-3 pr-4">Custom domain</td><td class="py-3 pr-4 text-center text-gray-600">✗</td><td class="py-3 pr-4 text-center text-gray-600">✗</td><td class="py-3 pr-4 text-center text-green-400">✓</td><td class="py-3 text-center text-green-400">✓</td></tr>
            <tr><td class="py-3 pr-4">Multi-location</td><td class="py-3 pr-4 text-center text-gray-600">✗</td><td class="py-3 pr-4 text-center text-gray-600">✗</td><td class="py-3 pr-4 text-center text-gray-600">✗</td><td class="py-3 text-center text-green-400">✓</td></tr>
            <tr><td class="py-3 pr-4">No InkFlow branding</td><td class="py-3 pr-4 text-center text-gray-600">✗</td><td class="py-3 pr-4 text-center text-gray-600">✗</td><td class="py-3 pr-4 text-center text-gray-600">✗</td><td class="py-3 text-center text-green-400">✓</td></tr>
            <tr><td class="py-3 pr-4">Priority support</td><td class="py-3 pr-4 text-center text-gray-600">✗</td><td class="py-3 pr-4 text-center text-gray-600">✗</td><td class="py-3 pr-4 text-center text-green-400">✓</td><td class="py-3 text-center text-green-400">✓</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- WHICH PLAN -->
  <section class="border-t border-ink-800/50 py-16 bg-ink-900/20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white text-center">Which Plan Is Right for You?</h2>
      <div class="mt-8 grid gap-4 md:grid-cols-4">
        <div class="rounded-xl border border-ink-800 p-5"><p class="text-white font-medium">🆓 Just starting out</p><p class="mt-1 text-sm text-gray-400">Free plan — basic manual tools. Test the waters.</p></div>
        <div class="rounded-xl border border-ink-800 p-5"><p class="text-white font-medium">🪪 Solo artist</p><p class="mt-1 text-sm text-gray-400">Go Starter ($9.99/mo). Online booking, waivers, cloud CRM, free website page.</p></div>
        <div class="rounded-xl border border-ink-800 p-5"><p class="text-white font-medium">🏪 Single shop with team</p><p class="mt-1 text-sm text-gray-400">Go Pro ($29.99/mo). 5 artists, commission, inventory, aftercare, enhanced website.</p></div>
        <div class="rounded-xl border border-ink-800 p-5"><p class="text-white font-medium">🏢 Multi-location studio</p><p class="mt-1 text-sm text-gray-400">Go Plus ($49.99 + $15/shop). All locations, one dashboard, unlimited website.</p></div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-ink-800/50 py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 space-y-4">
      <h2 class="text-2xl font-bold text-white text-center">Pricing FAQs</h2>
      <details class="rounded-xl border border-ink-800 p-4">
        <summary class="cursor-pointer text-sm font-medium text-white">Is there a free plan?</summary>
        <p class="mt-2 text-sm text-gray-400">Yes. Free forever — basic manual client management and booking. No cloud sync, no online booking. Upgrade to Starter for the full experience.</p>
      </details>
      <details class="rounded-xl border border-ink-800 p-4">
        <summary class="cursor-pointer text-sm font-medium text-white">What's the difference between Free and Starter?</summary>
        <p class="mt-2 text-sm text-gray-400">Free is manual and local-only. Starter adds online booking, digital waivers, CRM with cloud sync, SMS/email reminders, and payment collection.</p>
      </details>
      <details class="rounded-xl border border-ink-800 p-4">
        <summary class="cursor-pointer text-sm font-medium text-white">Can I switch plans later?</summary>
        <p class="mt-2 text-sm text-gray-400">Yes. Upgrade or downgrade anytime. Upgrades take effect immediately, downgrades at the next billing cycle.</p>
      </details>
      <details class="rounded-xl border border-ink-800 p-4">
        <summary class="cursor-pointer text-sm font-medium text-white">What's included in the beta period?</summary>
        <p class="mt-2 text-sm text-gray-400">During beta testing, all features are free on every plan. No payment needed. We'll notify you before the official launch.</p>
      </details>
      <details class="rounded-xl border border-ink-800 p-4">
        <summary class="cursor-pointer text-sm font-medium text-white">How does multi-shop pricing work on Plus?</summary>
        <p class="mt-2 text-sm text-gray-400">First shop is $29.99/mo. Each additional shop is $15/mo. All locations managed from one dashboard with cross-shop analytics.</p>
      </details>
    </div>
  </section>

  <!-- WEBSITE ONLY PLANS (from data source) -->
  <section class="border-t border-ink-800/50 py-16">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-sm font-semibold text-accent-400 mb-2">WEBSITE ONLY</p>
        <h2 class="text-2xl font-bold text-white">Just Need a Website?</h2>
        <p class="mt-2 text-gray-400 max-w-xl mx-auto">Get a tattoo shop website in minutes. Auto-generated from templates, Instagram gallery connected.</p>
      </div>
      <div class="grid gap-6 md:grid-cols-2 max-w-2xl mx-auto">

        {WEBSITE_PLANS.map((plan) => (
          <div class={`rounded-xl border ${plan.popular ? 'border-2 border-accent-500 bg-ink-900' : 'border-ink-800 bg-ink-900/30'} p-6 flex flex-col relative`}>
            {plan.popular && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-accent-500 px-3 py-0.5 text-xs font-semibold text-ink-950">Popular</span>
            )}
            <h3 class="text-base font-semibold text-white">{plan.name}</h3>
            <p class="mt-2 text-3xl font-bold text-white">{plan.annualLabel}</p>
            <p class="text-sm text-gray-400">{plan.subtitle}</p>
            <p class="text-xs text-gray-500">{plan.id === 'website_basic' ? 'Single landing page · Billed annually' : 'Multi-page website · Billed annually'} · Renews at {plan.annualLabel}</p>
            <ul class="mt-6 space-y-2 text-sm text-gray-400 flex-1">
              {plan.features.map((feat) => (
                <li class="flex items-start gap-2">
                  <span class="mt-0.5 text-accent-400 shrink-0">✓</span>
                  <span>{feat}</span>
                </li>
              ))}
            </ul>
            <p class="mt-3 text-xs text-gray-500">Zero storage cost — uses your Instagram photos</p>
            <a href={`https://app.ink-flows.com/register?type=website&plan=${plan.id}`}
               class={`mt-6 block w-full rounded-lg py-2 text-center text-sm transition-colors ${
                 plan.popular
                   ? 'bg-accent-500 text-ink-950 hover:bg-accent-400 font-semibold'
                   : 'border border-ink-700 text-gray-300 hover:border-ink-500'
               }`}>
              Get {plan.name === 'Website Basic' ? 'Basic' : 'Pro'}
            </a>
          </div>
        ))}

      </div>
      <p class="mt-6 text-center text-xs text-gray-500">Already have an InkFlow app plan? Your website is included. <a href="/pricing/" class="text-accent-400 hover:underline">See app plans</a></p>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-ink-800/50 py-16 text-center">
    <h2 class="text-3xl font-bold text-white">Start Free. No Credit Card Needed.</h2>
    <p class="mt-3 text-gray-400">All features are free during beta. No credit card required.</p>
    <a href="https://app.ink-flows.com/register" class="mt-8 inline-block rounded-lg bg-accent-500 px-10 py-4 text-lg font-semibold text-ink-950 hover:bg-accent-400 transition-all">Get Started Free →</a>
  </section>

  <Footer />
</BaseLayout>
