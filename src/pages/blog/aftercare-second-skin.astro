        <a href="/blog/tattoo-aftercare-guide" class="rounded-xl border border-ink-800 p-4 hover:border-accent-500/30 transition-all group"><p class="text-sm font-medium text-white group-hover:text-accent-300">Full guide</p><p class="text-xs text-gray-500 mt-1">By type &amp; placement</p></a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
