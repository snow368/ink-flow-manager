---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout lastUpdated="2026-07-16">
  <SEOHead slot="head" title="InkFlow Blog — Tattoo Studio Tips & Guides" description="Tips and guides for running a successful tattoo studio. From building your website to reducing no-shows and automating aftercare." appSchema={false} />
  <Navbar />

  <section class="pt-24 pb-20 sm:pt-32">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">InkFlow Blog</h1>
      <p class="mt-4 text-lg text-gray-400">Tips and guides for running a successful tattoo studio.</p>
    </div>
  </section>

  <!-- SECTION 1: Website Builder -->
  <section class="pb-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between border-b border-ink-800 pb-4">
        <h2 class="text-2xl font-bold text-white">Website Builder</h2>
        <a href="/blog/topic/website-builder" class="text-sm text-accent-400 hover:underline">All Website Builder resources →</a>
      </div>
      <p class="mt-3 text-sm text-gray-400">Get your studio a real website that ranks on Google — templates, design ideas, and how-to guides.</p>
      <div class="mt-8 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        <article class="rounded-xl border border-ink-800 bg-ink-900/30 p-6">
          <h2 class="text-lg font-semibold text-white hover:text-accent-300 transition-colors">
            <a href="/blog/how-to-make-a-tattoo-website">How to Make a Tattoo Website (Free, in 30 Minutes)</a>
          </h2>
          <p class="mt-2 text-sm text-gray-400">A step-by-step guide to launching a tattoo artist or studio website — no code, no designer.</p>
          <p class="mt-4 text-xs text-accent-400">Published July 16, 2026</p>
        </article>
        <article class="rounded-xl border border-ink-800 bg-ink-900/30 p-6">
          <h2 class="text-lg font-semibold text-white hover:text-accent-300 transition-colors">
            <a href="/blog/tattoo-website-design-ideas">Tattoo Website Design Ideas &amp; Layouts</a>
          </h2>
          <p class="mt-2 text-sm text-gray-400">Theme inspiration and layout patterns that convert visitors into bookings.</p>
          <p class="mt-4 text-xs text-accent-400">Published July 16, 2026</p>
        </article>
        <article class="rounded-xl border border-ink-800 bg-ink-900/30 p-6">
          <h2 class="text-lg font-semibold text-white hover:text-accent-300 transition-colors">
            <a href="/blog/tattoo-portfolio-website-examples">Tattoo Portfolio Website Examples</a>
          </h2>
          <p class="mt-2 text-sm text-gray-400">Real portfolio sites done right — what works, what to avoid, and how to stand out.</p>
          <p class="mt-4 text-xs text-accent-400">Published July 16, 2026</p>
        </article>
      </div>
    </div>
  </section>

  <!-- SECTION 2: Studio Ops & Marketing -->
  <section class="border-t border-ink-800/50 pb-20 pt-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="border-b border-ink-800 pb-4">
        <h2 class="text-2xl font-bold text-white">Studio Ops &amp; Marketing</h2>
      </div>
      <p class="mt-3 text-sm text-gray-400">Run a smoother studio — aftercare, waivers, inventory, no-shows, and automation.</p>
      <div class="mt-8 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        <article class="rounded-xl border border-ink-800 bg-ink-900/30 p-6">
          <h2 class="text-lg font-semibold text-white hover:text-accent-300 transition-colors">
            <a href="/blog/tattoo-aftercare-guide">Complete Tattoo Aftercare Guide 2026</a>
          </h2>
          <p class="mt-2 text-sm text-gray-400">Day-by-day healing timeline, aftercare by tattoo type, product recommendations, and red flag guide.</p>
          <p class="mt-4 text-xs text-accent-400">Published July 7, 2026</p>
        </article>
        <article class="rounded-xl border border-ink-800 bg-ink-900/30 p-6">
          <h2 class="text-lg font-semibold text-white hover:text-accent-300 transition-colors">
            <a href="/blog/how-to-digitize-tattoo-waivers">How to Digitize Tattoo Waivers in 2026</a>
          </h2>
          <p class="mt-2 text-sm text-gray-400">Go paperless with digital consent forms. Save time, reduce liability, and improve client experience.</p>
          <p class="mt-4 text-xs text-accent-400">Published May 28, 2026</p>
        </article>
        <article class="rounded-xl border border-ink-800 bg-ink-900/30 p-6">
          <h2 class="text-lg font-semibold text-white hover:text-accent-300 transition-colors">
            <a href="/blog/reduce-no-shows-deposit-booking">How to Reduce No-Shows in Your Tattoo Studio</a>
          </h2>
          <p class="mt-2 text-sm text-gray-400">7 proven strategies to cut no-shows and protect your revenue.</p>
          <p class="mt-4 text-xs text-accent-400">Published May 28, 2026</p>
        </article>
        <article class="rounded-xl border border-ink-800 bg-ink-900/30 p-6">
          <h2 class="text-lg font-semibold text-white hover:text-accent-300 transition-colors">
            <a href="/blog/tattoo-aftercare-automation">Tattoo Aftercare Automation Guide</a>
          </h2>
          <p class="mt-2 text-sm text-gray-400">Automate healing check-ins and review requests — on autopilot.</p>
          <p class="mt-4 text-xs text-accent-400">Published May 28, 2026</p>
        </article>
        <article class="rounded-xl border border-ink-800 bg-ink-900/30 p-6">
          <h2 class="text-lg font-semibold text-white hover:text-accent-300 transition-colors">
            <a href="/blog/tattoo-inventory-guide">Tattoo Shop Inventory Management Guide</a>
          </h2>
          <p class="mt-2 text-sm text-gray-400">Track ink, needles, and supplies. Never run out mid-session.</p>
          <p class="mt-4 text-xs text-accent-400">Published May 28, 2026</p>
        </article>
        <article class="rounded-xl border border-ink-800 bg-ink-900/30 p-6">
          <h2 class="text-lg font-semibold text-white hover:text-accent-300 transition-colors">
            <a href="/blog/multi-artist-commission-tracking">Multi-Artist Commission Tracking Explained</a>
          </h2>
          <p class="mt-2 text-sm text-gray-400">Set different rates and automate payouts. No spreadsheet math.</p>
          <p class="mt-4 text-xs text-accent-400">Published May 28, 2026</p>
        </article>
        <article class="rounded-xl border border-ink-800 bg-ink-900/30 p-6">
          <h2 class="text-lg font-semibold text-white hover:text-accent-300 transition-colors">
            <a href="/blog/aftercare-products">Tattoo Aftercare Products: What Actually Helps</a>
          </h2>
          <p class="mt-2 text-sm text-gray-400">The only 3 things you need — and what to skip.</p>
          <p class="mt-4 text-xs text-accent-400">Published July 15, 2026</p>
        </article>
        <article class="rounded-xl border border-ink-800 bg-ink-900/30 p-6">
          <h2 class="text-lg font-semibold text-white hover:text-accent-300 transition-colors">
            <a href="/blog/aftercare-issues">Tattoo Healing Issues: Normal vs Infection</a>
          </h2>
          <p class="mt-2 text-sm text-gray-400">Itching is normal. Spreading redness, pus, or fever are not.</p>
          <p class="mt-4 text-xs text-accent-400">Published July 15, 2026</p>
        </article>
        <article class="rounded-xl border border-ink-800 bg-ink-900/30 p-6">
          <h2 class="text-lg font-semibold text-white hover:text-accent-300 transition-colors">
            <a href="/blog/aftercare-color-tattoo">Color Tattoo Aftercare</a>
          </h2>
          <p class="mt-2 text-sm text-gray-400">Protect vibrancy: why color peels harder and fades faster.</p>
          <p class="mt-4 text-xs text-accent-400">Published July 15, 2026</p>
        </article>
        <article class="rounded-xl border border-ink-800 bg-ink-900/30 p-6">
          <h2 class="text-lg font-semibold text-white hover:text-accent-300 transition-colors">
            <a href="/blog/aftercare-second-skin">Second Skin Aftercare</a>
          </h2>
          <p class="mt-2 text-sm text-gray-400">How long to keep it, what pooling means, and what to do after.</p>
          <p class="mt-4 text-xs text-accent-400">Published July 15, 2026</p>
        </article>
        <article class="rounded-xl border border-ink-800 bg-ink-900/30 p-6">
          <h2 class="text-lg font-semibold text-white hover:text-accent-300 transition-colors">
            <a href="/blog/aftercare-timeline">Tattoo Healing Timeline</a>
          </h2>
          <p class="mt-2 text-sm text-gray-400">What to expect day by day, plus the 3–6 month deep heal.</p>
          <p class="mt-4 text-xs text-accent-400">Published July 15, 2026</p>
        </article>
        <article class="rounded-xl border border-ink-800 bg-ink-900/30 p-6">
          <h2 class="text-lg font-semibold text-white hover:text-accent-300 transition-colors">
            <a href="/blog/aftercare-activities">Tattoo Aftercare &amp; Activities</a>
          </h2>
          <p class="mt-2 text-sm text-gray-400">When you can shower, swim, gym, and use the sauna.</p>
          <p class="mt-4 text-xs text-accent-400">Published July 15, 2026</p>
        </article>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
