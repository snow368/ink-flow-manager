---
import DevGate from "../components/DevGate.astro";
import PageSchema from "../components/PageSchema.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import PageMeta from "../components/PageMeta.astro";
import { t, stripLocale } from "../i18n/utils";
import { DEFAULT_LOCALE, type Locale } from "../i18n/config";

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  /** 瑕嗙洊鑷姩鐢熸垚鐨勯潰鍖呭睉銆備笉浼犲垯鏍规嵁 URL 璺緞鑷姩鐢熸垚 */
  breadcrumbs?: BreadcrumbItem[];
  /** 褰撳墠椤甸潰鏍囬锛堢敤浜庨潰鍖呭睉鏈€鍚庝竴椤癸級 */
  pageTitle?: string;
  /** EEAT: 椤甸潰鏈€鍚庢洿鏂版棩鏈?YYYY-MM-DD */
  lastUpdated?: string;
  /** EEAT: 浣滆€呭悕 */
  author?: string;
  /** EEAT: 瀹℃牳鑰?*/
  reviewedBy?: string;
}

const { breadcrumbs, pageTitle, lastUpdated, author, reviewedBy } = Astro.props as Props;

const locale: Locale = (Astro.currentLocale as Locale) || DEFAULT_LOCALE;

// 鑷姩浠?URL 璺緞鐢熸垚闈㈠寘灞?
function autoBreadcrumbs(pathname: string, title?: string): BreadcrumbItem[] {
  const prefix = locale === 'es' ? '/es' : '';
  const cleaned = stripLocale(pathname);
  const parts = cleaned.replace(/\/$/, "").split("/").filter(Boolean);
  const items: BreadcrumbItem[] = [{ label: t(locale, 'breadcrumb.home'), href: prefix || '/' }];

  let current = "";
  for (let i = 0; i < parts.length; i++) {
    current += "/" + parts[i];
    const isLast = i === parts.length - 1;
    const label = isLast
      ? (title || parts[i].replace(/-/g, " "))
      : parts[i].replace(/-/g, " ");
    items.push(isLast
      ? { label: label }
      : { label: label, href: `${prefix}${current}` }
    );
  }
  return items;
}

const crumbs = breadcrumbs || autoBreadcrumbs(Astro.url.pathname, pageTitle);
const showBreadcrumb = stripLocale(Astro.url.pathname) !== "/";  // 棣栭〉涓嶆樉绀?

// EEAT: 璺緞鎺掗櫎瑙勫垯 鈥?棣栭〉/瀹氫环/About 绛変笉鏄剧ず PageMeta
const pathForMeta = stripLocale(Astro.url.pathname);
const excludePageMeta = ["/", "/pricing", "/about", "/contact", "/privacy", "/terms", "/templates", "/blog"]
  .some((p) => pathForMeta === p || pathForMeta.startsWith(p + "/"));
const showPageMeta = !!lastUpdated && !excludePageMeta;
---
<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Noto+Sans+SC:wght@400;500;700&display=swap" rel="stylesheet" />
    <PageSchema type="organization" />
    <slot name="head" />
  </head>
  <body class="bg-ink-950 text-gray-100 font-sans antialiased">
    <DevGate>
      {showBreadcrumb && <Breadcrumb items={crumbs} />}
      <PageMeta lastUpdated={lastUpdated} author={author} reviewedBy={reviewedBy} visible={showPageMeta} />
      <slot />
    </DevGate>
  </body>
</html>
